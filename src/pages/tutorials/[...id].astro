---
import ContentLayout from '@layouts/ContentLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const tutorials = await getCollection('tutorials');
  return tutorials.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Compute prev/next and related articles
const allEntries = (await getCollection('tutorials', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const currentIndex = allEntries.findIndex((e) => e.id === entry.id);
const prevEntry = currentIndex < allEntries.length - 1 ? allEntries[currentIndex + 1] : null;
const nextEntry = currentIndex > 0 ? allEntries[currentIndex - 1] : null;

const prevArticle = prevEntry ? { title: prevEntry.data.title, href: `/tutorials/${prevEntry.id}/` } : null;
const nextArticle = nextEntry ? { title: nextEntry.data.title, href: `/tutorials/${nextEntry.id}/` } : null;

// Related: same category first, then others, excluding current, max 3
const others = allEntries.filter((e) => e.id !== entry.id);
const sameCategory = others.filter((e) => e.data.category === entry.data.category);
const different = others.filter((e) => e.data.category !== entry.data.category);
const relatedRaw = [...sameCategory, ...different].slice(0, 3);

const relatedArticles = relatedRaw.map((e) => ({
  title: e.data.title,
  description: e.data.description,
  href: `/tutorials/${e.id}/`,
  pubDate: e.data.pubDate,
  tags: e.data.tags,
  difficulty: e.data.difficulty,
  image: e.data.image,
  body: e.body || '',
  category: e.data.category,
  collection: 'tutorials',
}));
---

<ContentLayout
  title={entry.data.title}
  description={entry.data.description}
  pubDate={entry.data.pubDate}
  author={entry.data.author}
  image={entry.data.image}
  tags={entry.data.tags}
  difficulty={entry.data.difficulty}
  estimatedTime={entry.data.estimatedTime}
  body={entry.body || ''}
  collection="tutorials"
  id={entry.id}
  category={entry.data.category}
  prevArticle={prevArticle}
  nextArticle={nextArticle}
  relatedArticles={relatedArticles}
>
  <Content />
</ContentLayout>
