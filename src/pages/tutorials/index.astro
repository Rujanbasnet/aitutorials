---
import BaseLayout from '@layouts/BaseLayout.astro';
import PostCard from '@components/content/PostCard.astro';
import FeaturedPost from '@components/content/FeaturedPost.astro';
import { getPublishedTutorials } from '@utils/collections';

const tutorials = await getPublishedTutorials();
const featured = tutorials[0];
const rest = tutorials.slice(1);
const categories = ['all', 'prompt-engineering', 'ai-tools', 'automation', 'coding-with-ai', 'ai-agents', 'machine-learning'];

const categoryLabels: Record<string, string> = {
  'all': 'All',
  'prompt-engineering': 'Prompt Engineering',
  'ai-tools': 'AI Tools',
  'automation': 'Automation',
  'coding-with-ai': 'Coding with AI',
  'ai-agents': 'AI Agents',
  'machine-learning': 'Machine Learning',
};
---

<BaseLayout title="AI Tutorials" description="Step-by-step AI tutorials from beginner to advanced. Learn prompt engineering, AI tools, automation, and more.">

  <!-- Warm editorial hero -->
  <section class="tut-hero">
    <div class="tut-hero__bg" aria-hidden="true">
      <div class="tut-hero__texture"></div>
      <div class="tut-hero__gradient"></div>
      <canvas class="tut-hero__canvas" id="tut-canvas"></canvas>
    </div>

    <div class="tut-hero__inner">
      <div class="tut-hero__content">
        <span class="tut-hero__tag">Learn</span>
        <h1 class="tut-hero__title">AI Tutorials</h1>
        <p class="tut-hero__sub">
          Step-by-step guides to master AI tools, prompt engineering, and automation. From beginner to advanced.
        </p>

        <div class="tut-hero__stats">
          <div class="tut-hero__stat">
            <span class="tut-hero__stat-num">{tutorials.length}</span>
            <span class="tut-hero__stat-label">tutorials</span>
          </div>
          <div class="tut-hero__stat-dot"></div>
          <div class="tut-hero__stat">
            <span class="tut-hero__stat-label">Beginner to advanced</span>
          </div>
          <div class="tut-hero__stat-dot"></div>
          <div class="tut-hero__stat">
            <span class="tut-hero__stat-label">Updated regularly</span>
          </div>
        </div>
      </div>

      <!-- Decorative image card -->
      <div class="tut-hero__visual">
        <div class="tut-hero__img-card">
          <img
            src="/images/tutorials/robot-books.webp"
            alt="A robot studying AI books"
            class="tut-hero__img"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Category Filter -->
    <div class="flex flex-wrap gap-2 mb-10" id="filter-bar">
      {categories.map((cat) => (
        <button
          class:list={[
            'filter-btn px-4 py-2 rounded-xl text-sm font-medium border transition-all',
            cat === 'all'
              ? 'filter-active'
              : 'border-[var(--color-border)] text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:border-[var(--color-border-strong)]',
          ]}
          data-filter={cat}
        >
          {categoryLabels[cat] || cat}
        </button>
      ))}
    </div>

    <!-- Related resource links -->
    <div class="flex flex-wrap gap-2 mb-10">
      <a href="/non-coder/" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-xl text-sm font-medium border border-[var(--color-border)] text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:border-[var(--color-border-strong)] transition-all">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0" /></svg>
        Non-Coder Guides
      </a>
      <a href="/resources/" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-xl text-sm font-medium border border-[var(--color-border)] text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:border-[var(--color-border-strong)] transition-all">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>
        Cheatsheets & Resources
      </a>
    </div>

    {tutorials.length > 0 ? (
      <div id="tutorial-grid">
        <!-- Featured latest tutorial -->
        {featured && (
          <div class="mb-8 fade-in" data-category={featured.data.category}>
            <FeaturedPost
              title={featured.data.title}
              description={featured.data.description}
              href={`/tutorials/${featured.id}/`}
              pubDate={featured.data.pubDate}
              tags={featured.data.tags}
              image={featured.data.image}
              body={featured.body || ''}
              category={featured.data.category}
              collection="tutorials"
            />
          </div>
        )}

        <!-- Rest of tutorials -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger">
          {rest.map((tutorial) => (
            <div class="fade-in" data-category={tutorial.data.category}>
              <PostCard
                title={tutorial.data.title}
                description={tutorial.data.description}
                href={`/tutorials/${tutorial.id}/`}
                pubDate={tutorial.data.pubDate}
                tags={tutorial.data.tags}
                difficulty={tutorial.data.difficulty}
                image={tutorial.data.image}
                body={tutorial.body || ''}
                category={tutorial.data.category}
                collection="tutorials"
              />
            </div>
          ))}
        </div>
      </div>
    ) : (
      <div class="card-warm p-16 text-center rounded-xl">
        <h3 class="text-heading mb-2">Coming soon</h3>
        <p class="text-[var(--color-text-secondary)]">Tutorials are being written. Check back soon or subscribe to get notified.</p>
      </div>
    )}
  </section>

  <!-- CTA -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 text-center">
    <div class="tut-cta">
      <h3 class="text-heading mb-3">Not sure where to start?</h3>
      <p class="text-[var(--color-text-secondary)] mb-6 max-w-md mx-auto">Pick a learning path based on your experience level and goals. We'll guide you through it step by step.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/start/" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-[var(--color-accent)] text-white font-semibold hover:bg-[var(--color-accent-hover)] transition-all hover:shadow-[0_8px_24px_rgba(217,119,6,0.25)] hover:-translate-y-0.5 text-sm">
          Start here
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
        </a>
        <a href="/challenges/" class="inline-flex items-center px-6 py-3 rounded-xl border border-[var(--color-border-strong)] text-[var(--color-text-secondary)] font-medium hover:border-[var(--color-text-primary)] hover:text-[var(--color-text-primary)] transition-colors text-sm">
          Try a challenge
        </a>
      </div>
    </div>
  </section>

  <script>
    const buttons = document.querySelectorAll<HTMLButtonElement>('#filter-bar [data-filter]');
    const allCards = document.querySelectorAll<HTMLElement>('#tutorial-grid [data-category]');

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        buttons.forEach((b) => b.classList.remove('filter-active'));
        btn.classList.add('filter-active');

        const filter = btn.dataset.filter;
        allCards.forEach((card) => {
          if (filter === 'all' || card.dataset.category === filter) {
            card.style.display = '';
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
  </script>

</BaseLayout>

<style>
  /* ── Hero ─────────────────────────────────── */
  .tut-hero {
    position: relative;
    overflow: hidden;
    background: #F8F5F0;
  }
  .tut-hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .tut-hero__texture {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    opacity: 0.03;
  }
  .tut-hero__gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 20% 80%, var(--color-sage-soft) 0%, transparent 50%),
      radial-gradient(ellipse 50% 40% at 80% 20%, var(--color-accent-soft) 0%, transparent 50%);
    opacity: 0.6;
  }
  .tut-hero__inner {
    position: relative;
    max-width: 72rem;
    margin: 0 auto;
    padding: 4rem clamp(20px, 5vw, 48px) 5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
  }
  @media (min-width: 768px) {
    .tut-hero__inner {
      grid-template-columns: 1.2fr 0.8fr;
      padding: 5rem clamp(20px, 5vw, 48px) 6rem;
    }
  }

  .tut-hero__tag {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent-hover);
    background: var(--color-accent-soft);
    padding: 4px 14px;
    border-radius: 100px;
    margin-bottom: 16px;
    animation: tut-fade-up 0.7s ease 0.1s both;
  }
  .tut-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 2rem + 3vw, 4.5rem);
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--color-text-primary);
    margin-bottom: 16px;
    animation: tut-fade-up 0.7s ease 0.2s both;
  }
  .tut-hero__sub {
    font-size: clamp(0.9375rem, 0.85rem + 0.4vw, 1.0625rem);
    line-height: 1.7;
    color: var(--color-text-secondary);
    max-width: 460px;
    animation: tut-fade-up 0.7s ease 0.3s both;
  }
  .tut-hero__stats {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
    margin-top: 28px;
    animation: tut-fade-up 0.7s ease 0.4s both;
  }
  .tut-hero__stat { display: flex; align-items: baseline; gap: 6px; }
  .tut-hero__stat-num {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-text-primary);
  }
  .tut-hero__stat-label {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }
  .tut-hero__stat-dot {
    width: 3px; height: 3px;
    border-radius: 50%;
    background: var(--color-border-strong);
  }

  /* Decorative image */
  .tut-hero__visual {
    display: none;
    animation: tut-fade-up 0.8s ease 0.3s both;
  }
  @media (min-width: 768px) {
    .tut-hero__visual { display: block; }
  }
  .tut-hero__img-card {
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow:
      0 16px 48px -12px rgba(120,53,15,0.1),
      0 4px 12px -4px rgba(20,20,19,0.06);
    transform: rotate(2deg);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .tut-hero__img-card:hover {
    transform: rotate(0deg) scale(1.02);
  }
  .tut-hero__img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 4/3;
    object-fit: cover;
  }

  @keyframes tut-fade-up {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ── Filter buttons ──────────────────────── */
  .filter-btn {
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .filter-btn:hover {
    transform: translateY(-1px);
  }

  /* ── CTA ──────────────────────────────────── */
  .tut-cta {
    background: var(--color-bg-warm);
    padding: 2.5rem;
    border-radius: 1.25rem;
    border: 1px solid var(--color-border);
    position: relative;
    overflow: hidden;
  }
  .tut-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, var(--color-accent-soft) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.4s;
  }
  .tut-cta:hover::before { opacity: 0.4; }
  .tut-cta > * { position: relative; }

  /* -- Canvas animation ---------------------- */
  .tut-hero__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .tut-hero__tag,
    .tut-hero__title,
    .tut-hero__sub,
    .tut-hero__stats,
    .tut-hero__visual { animation: none; opacity: 1; }
    .filter-btn { transition: none; }
    .tut-hero__img-card { transition: none; }
    .tut-hero__canvas { display: none !important; }
  }
</style>

<script is:inline>
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    var canvas = document.getElementById('tut-canvas');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    if (!ctx) return;

    var hero = document.querySelector('.tut-hero');
    if (!hero) return;

    var mouseX = -9999, mouseY = -9999;
    hero.addEventListener('mousemove', function (e) {
      var rect = hero.getBoundingClientRect();
      mouseX = e.clientX - rect.left;
      mouseY = e.clientY - rect.top;
    });
    hero.addEventListener('mouseleave', function () {
      mouseX = -9999;
      mouseY = -9999;
    });

    var colors = [
      { r: 217, g: 119, b: 6 },   // accent/amber
      { r: 45, g: 106, b: 79 },    // sage
      { r: 160, g: 120, b: 60 },   // warm gold
    ];

    var pages = [];
    var isMobile = window.innerWidth < 768;
    var count = isMobile ? 10 : 20;

    function resize() {
      var rect = hero.getBoundingClientRect();
      canvas.width = rect.width;
      canvas.height = rect.height;
    }

    function rand(min, max) {
      return Math.random() * (max - min) + min;
    }

    function init() {
      isMobile = window.innerWidth < 768;
      count = isMobile ? 10 : 20;
      resize();
      pages = [];
      for (var i = 0; i < count; i++) {
        var c = colors[Math.floor(Math.random() * colors.length)];
        pages.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          w: rand(8, 18),
          h: rand(10, 24),
          vx: (Math.random() < 0.5 ? 1 : -1) * rand(0.08, 0.25),
          vy: rand(-0.4, -0.1),
          rotation: Math.random() * Math.PI * 2,
          rotSpeed: (Math.random() < 0.5 ? 1 : -1) * rand(0.003, 0.01),
          color: c,
          opacity: rand(0.04, 0.12),
          strokeOpacity: rand(0.15, 0.35),
        });
      }
    }

    function drawPage(x, y, w, h, angle) {
      ctx.save();
      ctx.translate(x, y);
      ctx.rotate(angle);
      // Page body
      ctx.beginPath();
      ctx.moveTo(-w / 2, -h / 2);
      ctx.lineTo(w / 2 - 3, -h / 2);
      ctx.lineTo(w / 2, -h / 2 + 3);
      ctx.lineTo(w / 2, h / 2);
      ctx.lineTo(-w / 2, h / 2);
      ctx.closePath();
      // Dog-ear fold
      ctx.moveTo(w / 2 - 3, -h / 2);
      ctx.lineTo(w / 2 - 3, -h / 2 + 3);
      ctx.lineTo(w / 2, -h / 2 + 3);
      ctx.restore();
    }

    function animate() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      var w = canvas.width, h = canvas.height;

      for (var i = 0; i < pages.length; i++) {
        var p = pages[i];

        // Gentle mouse attraction (pages drift toward cursor like curiosity)
        var dx = mouseX - p.x;
        var dy = mouseY - p.y;
        var dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 200 && dist > 0) {
          var pull = (200 - dist) / 200 * 0.15;
          p.x += (dx / dist) * pull;
          p.y += (dy / dist) * pull;
        }

        p.x += p.vx;
        p.y += p.vy;
        p.rotation += p.rotSpeed;

        // Wrap: float up and reappear at bottom
        if (p.y < -p.h) {
          p.y = h + p.h;
          p.x = Math.random() * w;
        }
        if (p.x < -p.w) p.x = w + p.w;
        if (p.x > w + p.w) p.x = -p.w;
      }

      // Draw connecting lines between nearby pages
      for (var i = 0; i < pages.length; i++) {
        for (var j = i + 1; j < pages.length; j++) {
          var a = pages[i], b = pages[j];
          var ddx = a.x - b.x, ddy = a.y - b.y;
          var d = Math.sqrt(ddx * ddx + ddy * ddy);
          if (d < 120) {
            var alpha = (1 - d / 120) * 0.08;
            ctx.beginPath();
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(b.x, b.y);
            ctx.strokeStyle = 'rgba(160, 120, 60, ' + alpha + ')';
            ctx.lineWidth = 0.6;
            ctx.stroke();
          }
        }
      }

      // Draw pages
      for (var i = 0; i < pages.length; i++) {
        var p = pages[i];
        var c = p.color;
        drawPage(p.x, p.y, p.w, p.h, p.rotation);
        ctx.fillStyle = 'rgba(' + c.r + ',' + c.g + ',' + c.b + ',' + p.opacity + ')';
        ctx.fill();
        ctx.strokeStyle = 'rgba(' + c.r + ',' + c.g + ',' + c.b + ',' + p.strokeOpacity + ')';
        ctx.lineWidth = 1;
        ctx.stroke();
      }

      requestAnimationFrame(animate);
    }

    init();
    window.addEventListener('resize', function () { init(); });
    animate();
  })();
</script>
