---
import BaseLayout from '@layouts/BaseLayout.astro';
import { formatDateShort } from '@utils/dates';
import { getReadingTime } from '@utils/reading-time';
import { getPublishedTutorials, getPublishedNews, getPublishedBlog, getLearningPathsWithTime } from '@utils/collections';

const tutorials = await getPublishedTutorials();
const news = await getPublishedNews();
const blog = await getPublishedBlog();
const learningPaths = await getLearningPathsWithTime();

const featured = tutorials[0];
const latestTutorials = tutorials.slice(1, 5);
const latestNews = news.slice(0, 3);
const latestBlog = blog.slice(0, 3);

const foundationsPath = learningPaths.find(p => p.id === 'ai-foundations');
const automationPath = learningPaths.find(p => p.id === 'automation-builder');
---

<BaseLayout title="AI Tutorials" description="Learn AI, build with AI, ship faster. Tutorials, news, and tools for the AI era.">

  <!-- ══════ HERO — Warm editorial with 3D floating card ══════ -->
  <section class="hp-hero" id="hero">
    <div class="hp-hero__bg" aria-hidden="true">
      <div class="hp-hero__texture"></div>
      <div class="hp-hero__gradient"></div>
      <div class="hp-hero__orb hp-hero__orb--1" id="orb1"></div>
      <div class="hp-hero__orb hp-hero__orb--2" id="orb2"></div>
      <div class="hp-hero__orb hp-hero__orb--3" id="orb3"></div>
      <div class="hp-hero__border-line"></div>
    </div>

    <div class="hp-hero__inner">
      <!-- Left: Copy -->
      <div class="hp-hero__copy">
        <div class="hp-hero__eyebrow">
          <span class="hp-hero__eyebrow-dot"></span>
          <span>Free AI Learning Platform</span>
        </div>

        <h1 class="hp-hero__h1">
          <span class="hp-hero__line" style="--i:0">AI doesn't have</span>
          <span class="hp-hero__line" style="--i:1">to be <em class="hp-hero__keyword">complicated.</em></span>
        </h1>

        <p class="hp-hero__sub">
          Practical tutorials that break down AI tools, prompts, and workflows into steps anyone can follow. No coding. No jargon. Just results.
        </p>

        <div class="hp-hero__actions">
          <a href="/start/" class="hp-btn hp-btn--glow">
            Start learning
            <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </a>
          <a href="/tutorials/" class="hp-btn hp-btn--outline">Browse tutorials</a>
        </div>

        <div class="hp-hero__stats">
          <div class="hp-hero__stat">
            <span class="hp-hero__stat-num">{tutorials.length}+</span>
            <span class="hp-hero__stat-label">Tutorials</span>
          </div>
          <div class="hp-hero__stat-sep"></div>
          <div class="hp-hero__stat">
            <span class="hp-hero__stat-num">{news.length}+</span>
            <span class="hp-hero__stat-label">News Articles</span>
          </div>
          <div class="hp-hero__stat-sep"></div>
          <div class="hp-hero__stat">
            <span class="hp-hero__stat-num">Free</span>
            <span class="hp-hero__stat-label">Always</span>
          </div>
        </div>
      </div>

      <!-- Right: Stacked editorial cards -->
      <div class="hp-hero__visual" id="hero-visual">
        <div class="hp-hero__stack" id="hero-card">
          <div class="hp-hero__card-shine" id="card-shine"></div>

          <!-- Back card (deepest) -->
          <div class="hp-stack__card hp-stack__card--3">
            <span class="hp-stack__label">Tutorial</span>
            <span class="hp-stack__tag badge-beginner">Beginner</span>
          </div>

          <!-- Middle card -->
          <div class="hp-stack__card hp-stack__card--2">
            <span class="hp-stack__label">News</span>
            <h4 class="hp-stack__title">{news[0]?.data.title || 'Latest AI News'}</h4>
            <span class="hp-stack__meta">{formatDateShort(news[0]?.data.pubDate || new Date())}</span>
          </div>

          <!-- Front card (top) -->
          <div class="hp-stack__card hp-stack__card--1">
            <div class="hp-stack__accent-bar"></div>
            <span class="hp-stack__label">Latest Tutorial</span>
            <h4 class="hp-stack__title hp-stack__title--lg">{featured?.data.title || 'Getting Started with AI'}</h4>
            <p class="hp-stack__desc">{featured?.data.description?.slice(0, 100) || 'Learn the fundamentals'}...</p>
            <div class="hp-stack__foot">
              <span class="hp-stack__meta">{getReadingTime(featured?.body || '')}</span>
              <span class="hp-stack__arrow">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" /></svg>
              </span>
            </div>
          </div>

          <!-- Floating topic pills -->
          <div class="hp-hero__float hp-hero__float--1" id="float1">
            Prompt Engineering
          </div>
          <div class="hp-hero__float hp-hero__float--2" id="float2">
            Automation
          </div>
          <div class="hp-hero__float hp-hero__float--3" id="float3">
            AI Tools
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="hp-hero__scroll" aria-hidden="true">
      <div class="hp-hero__scroll-line">
        <div class="hp-hero__scroll-dot"></div>
      </div>
    </div>
  </section>

  <!-- Editorial divider -->
  <div class="hp-divider" aria-hidden="true">
    <span class="hp-divider__line"></span>
    <span class="hp-divider__diamond"></span>
    <span class="hp-divider__line"></span>
  </div>

  <!-- ══════ PICK YOUR PATH — 3D tilt cards ══════ -->
  <section class="hp-paths" id="paths-section">
    <div class="hp-container">
      <div class="hp-section-header">
        <span class="hp-section-tag">Where to start</span>
        <h2 class="hp-section-title">Pick your path</h2>
        <p class="hp-section-sub">Choose what fits you. Every path is free, self-paced, and designed for people who don't code.</p>
      </div>

      <div class="hp-paths__grid">
        <!-- Path 1: New to AI -->
        <a href="/paths/ai-foundations/" class="hp-path-card" data-tilt data-color="sage">
          <div class="hp-path-card__inner">
            <div class="hp-path-card__shine"></div>
            <div class="hp-path-card__icon" style="--icon-bg: var(--color-sage-soft); --icon-color: var(--color-sage);">
              <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
              </svg>
            </div>
            <span class="badge-beginner hp-path-card__badge">Beginner</span>
            <h3 class="hp-path-card__title">I'm completely new to AI</h3>
            <p class="hp-path-card__desc">Learn what AI actually is, how to talk to it effectively, and which tools are worth your time.</p>
            {foundationsPath && (
              <span class="hp-path-card__meta">{foundationsPath.stepCount} tutorials &middot; {foundationsPath.totalTime}</span>
            )}
            <span class="hp-path-card__cta" style="--cta-color: var(--color-sage);">
              Start learning
              <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </span>
          </div>
        </a>

        <!-- Path 2: Find Tools -->
        <a href="/tools/" class="hp-path-card" data-tilt data-color="amber">
          <div class="hp-path-card__inner">
            <div class="hp-path-card__shine"></div>
            <div class="hp-path-card__icon" style="--icon-bg: var(--color-accent-soft); --icon-color: var(--color-accent);">
              <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
              </svg>
            </div>
            <span class="hp-path-card__badge" style="background: var(--color-accent-soft); color: var(--color-accent);">Explore</span>
            <h3 class="hp-path-card__title">I want to find the right tools</h3>
            <p class="hp-path-card__desc">Browse 24+ curated AI tools with honest descriptions, pricing, and categories.</p>
            <span class="hp-path-card__meta">24 tools &middot; 9 categories</span>
            <span class="hp-path-card__cta" style="--cta-color: var(--color-accent);">
              Browse tools
              <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </span>
          </div>
        </a>

        <!-- Path 3: Automate -->
        <a href="/paths/automation-builder/" class="hp-path-card" data-tilt data-color="clay">
          <div class="hp-path-card__inner">
            <div class="hp-path-card__shine"></div>
            <div class="hp-path-card__icon" style="--icon-bg: var(--color-clay-soft); --icon-color: var(--color-clay);">
              <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
              </svg>
            </div>
            <span class="badge-intermediate hp-path-card__badge">Intermediate</span>
            <h3 class="hp-path-card__title">I want to automate my work</h3>
            <p class="hp-path-card__desc">Build AI workflows that handle repetitive tasks. Save hours every week with practical automation.</p>
            {automationPath && (
              <span class="hp-path-card__meta">{automationPath.stepCount} tutorials &middot; {automationPath.totalTime}</span>
            )}
            <span class="hp-path-card__cta" style="--cta-color: var(--color-clay);">
              Start building
              <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </span>
          </div>
        </a>

        <!-- Path 4: Try It Now -->
        <a href="/challenges/" class="hp-path-card" data-tilt data-color="multi">
          <div class="hp-path-card__inner">
            <div class="hp-path-card__shine"></div>
            <div class="hp-path-card__icon" style="--icon-bg: linear-gradient(135deg, var(--color-accent-soft), var(--color-sage-soft)); --icon-color: var(--color-accent);">
              <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" />
              </svg>
            </div>
            <span class="hp-path-card__badge" style="background: var(--color-clay-soft); color: var(--color-clay);">Instant</span>
            <h3 class="hp-path-card__title">Show me AI magic right now</h3>
            <p class="hp-path-card__desc">Copy a prompt, paste it into ChatGPT or Claude, build something incredible in 2 minutes.</p>
            <span class="hp-path-card__meta">6 challenges &middot; 2-5 min each</span>
            <span class="hp-path-card__cta" style="--cta-color: var(--color-accent);">
              Try it now
              <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ══════ FEATURED + LATEST ══════ -->
  {featured && (
    <section class="hp-content">
      <div class="hp-container">
        <div class="hp-section-header hp-section-header--row">
          <div>
            <span class="hp-section-tag">Latest content</span>
            <h2 class="hp-section-title">Fresh tutorials</h2>
          </div>
          <a href="/tutorials/" class="hp-link-arrow">
            View all
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
          </a>
        </div>

        <!-- Featured article — large card with parallax image -->
        <a href={`/tutorials/${featured.id}/`} class="hp-feat" id="feat-card" data-tilt-subtle>
          <div class="hp-feat__img-wrap">
            <img
              src="/images/tutorials/robot-books.webp"
              alt={featured.data.title}
              class="hp-feat__img"
              id="feat-img"
              loading="eager"
            />
            <div class="hp-feat__img-overlay"></div>
            <div class="hp-feat__badge-wrap">
              <span class="hp-feat__badge">Featured</span>
            </div>
          </div>
          <div class="hp-feat__body">
            <div class="hp-feat__meta">
              <time datetime={featured.data.pubDate.toISOString()}>{formatDateShort(featured.data.pubDate)}</time>
              <span class="hp-feat__meta-dot"></span>
              <span>{getReadingTime(featured.body || '')}</span>
              {featured.data.difficulty && (
                <>
                  <span class="hp-feat__meta-dot"></span>
                  <span class:list={[
                    'text-xs font-semibold px-2 py-0.5 rounded-sm uppercase tracking-wide',
                    featured.data.difficulty === 'beginner' ? 'badge-beginner' :
                    featured.data.difficulty === 'intermediate' ? 'badge-intermediate' : 'badge-advanced',
                  ]}>
                    {featured.data.difficulty}
                  </span>
                </>
              )}
            </div>
            <h3 class="hp-feat__title">{featured.data.title}</h3>
            <p class="hp-feat__desc">{featured.data.description}</p>
            <span class="hp-feat__cta">
              Read article
              <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </span>
          </div>
        </a>

        <!-- Latest tutorials grid -->
        {latestTutorials.length > 0 && (
          <div class="hp-tuts-grid">
            {latestTutorials.map((t, i) => (
              <a href={`/tutorials/${t.id}/`} class="hp-tut" data-tilt-subtle style={`--stagger: ${i * 0.08}s`}>
                <div class="hp-tut__top">
                  {t.data.difficulty && (
                    <span class:list={[
                      'text-xs font-semibold px-2 py-0.5 rounded-sm uppercase tracking-wide',
                      t.data.difficulty === 'beginner' ? 'badge-beginner' :
                      t.data.difficulty === 'intermediate' ? 'badge-intermediate' : 'badge-advanced',
                    ]}>
                      {t.data.difficulty}
                    </span>
                  )}
                  <span class="hp-tut__time">{getReadingTime(t.body || '')}</span>
                </div>
                <h3 class="hp-tut__title">{t.data.title}</h3>
                <p class="hp-tut__desc">{t.data.description}</p>
                <div class="hp-tut__foot">
                  <time datetime={t.data.pubDate.toISOString()}>{formatDateShort(t.data.pubDate)}</time>
                  <span class="hp-tut__arrow">
                    <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" /></svg>
                  </span>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    </section>
  )}

  <!-- Editorial divider -->
  <div class="hp-divider" aria-hidden="true">
    <span class="hp-divider__line"></span>
    <span class="hp-divider__diamond"></span>
    <span class="hp-divider__line"></span>
  </div>

  <!-- ══════ NEWS + BLOG combined ══════ -->
  <section class="hp-feed">
    <div class="hp-container">
      <div class="hp-feed__cols">
        <!-- News column -->
        {latestNews.length > 0 && (
          <div class="hp-feed__col">
            <div class="hp-section-header hp-section-header--row hp-section-header--sm">
              <h2 class="hp-section-title hp-section-title--sm">AI News</h2>
              <a href="/news/" class="hp-link-arrow hp-link-arrow--sm">All news <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg></a>
            </div>
            <div class="hp-feed__list">
              {latestNews.map((n, i) => (
                <a href={`/news/${n.id}/`} class="hp-feed__item">
                  <span class="hp-feed__num">{String(i + 1).padStart(2, '0')}</span>
                  <div class="hp-feed__item-body">
                    <h4 class="hp-feed__item-title">{n.data.title}</h4>
                    <time class="hp-feed__item-date" datetime={n.data.pubDate.toISOString()}>{formatDateShort(n.data.pubDate)}</time>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Blog column -->
        {latestBlog.length > 0 && (
          <div class="hp-feed__col">
            <div class="hp-section-header hp-section-header--row hp-section-header--sm">
              <h2 class="hp-section-title hp-section-title--sm">From the Blog</h2>
              <a href="/blog/" class="hp-link-arrow hp-link-arrow--sm">All posts <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg></a>
            </div>
            <div class="hp-feed__list">
              {latestBlog.map((b, i) => (
                <a href={`/blog/${b.id}/`} class="hp-feed__item">
                  <span class="hp-feed__num">{String(i + 1).padStart(2, '0')}</span>
                  <div class="hp-feed__item-body">
                    <h4 class="hp-feed__item-title">{b.data.title}</h4>
                    <div class="hp-feed__item-tags">
                      {b.data.tags.slice(0, 2).map((tag) => (
                        <span class="tag">{tag}</span>
                      ))}
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- ══════ NEWSLETTER CTA — Dramatic dark section ══════ -->
  <section class="hp-cta">
    <div class="hp-cta__bg" aria-hidden="true">
      <div class="hp-cta__dots"></div>
      <div class="hp-cta__orb hp-cta__orb--1"></div>
      <div class="hp-cta__orb hp-cta__orb--2"></div>
    </div>
    <div class="hp-container hp-cta__inner">
      <div class="hp-cta__left">
        <span class="hp-cta__tag">Newsletter</span>
        <h2 class="hp-cta__heading">Stay sharp<br/>on AI</h2>
        <p class="hp-cta__text">Weekly curated tutorials, tool reviews, and industry insights. No spam, unsubscribe anytime.</p>
      </div>
      <div class="hp-cta__right">
        <form
          id="hp-newsletter-form"
          method="POST"
          action="https://b4556b17.sibforms.com/serve/MUIFAHjyU7YMpzSHJctCG76TeifU-zeadE5xjY7m1BVB8OAp92-d_PQhCoOWQEOmk4MS7WNag_cREDOfr2gD_9admQ-lmt1YRRSin829IqgP-7m6OgZ0UjrDdasmFSz8flCQlk8y_YBI-lKiQQ9qqxWgkhUmBJsqzUenQVwYH8PQvtI1fDVLICJxRSqP5KofXY00WORK9nXSGAsqiQ=="
          class="hp-cta__form"
        >
          <div class="hp-cta__input-group">
            <input
              type="email"
              name="EMAIL"
              required
              placeholder="Your email address"
              class="hp-cta__input"
            />
            <button type="submit" class="hp-btn hp-btn--glow hp-cta__submit">
              Subscribe
              <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </button>
          </div>
          <div style="position: absolute; left: -5000px;" aria-hidden="true">
            <input type="text" name="email_address_check" value="" tabindex="-1" autocomplete="off" />
          </div>
          <input type="hidden" name="locale" value="en" />
          <p class="hp-cta__fine">Join 100+ subscribers. One email per week.</p>
        </form>
        <div id="hp-newsletter-success" class="hp-cta__success" style="display:none;">
          <p>You're in! Check your inbox to confirm.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════ SCRIPTS ══════ -->
  <script is:inline>
    // ── Newsletter form handler ──
    const hpForm = document.getElementById('hp-newsletter-form');
    if (hpForm) {
      hpForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(hpForm);
        const btn = hpForm.querySelector('button[type="submit"]');
        const originalHTML = btn.innerHTML;
        btn.textContent = 'Subscribing...';
        btn.disabled = true;
        try {
          await fetch(hpForm.action, { method: 'POST', body: formData, mode: 'no-cors' });
          hpForm.style.display = 'none';
          document.getElementById('hp-newsletter-success').style.display = 'block';
        } catch (err) {
          btn.innerHTML = originalHTML;
          btn.disabled = false;
        }
      });
    }

    // ── 3D Tilt Effect for cards ──
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!prefersReduced) {
      // Hero card 3D tilt
      const heroVisual = document.getElementById('hero-visual');
      const heroCard = document.getElementById('hero-card');
      const cardShine = document.getElementById('card-shine');
      const float1 = document.getElementById('float1');
      const float2 = document.getElementById('float2');
      const float3 = document.getElementById('float3');

      if (heroVisual && heroCard) {
        heroVisual.addEventListener('mousemove', (e) => {
          const rect = heroVisual.getBoundingClientRect();
          const x = (e.clientX - rect.left) / rect.width - 0.5;
          const y = (e.clientY - rect.top) / rect.height - 0.5;

          heroCard.style.transform =
            `perspective(1200px) rotateY(${x * 14}deg) rotateX(${-y * 14}deg) scale3d(1.01, 1.01, 1.01)`;

          if (cardShine) {
            cardShine.style.background =
              `radial-gradient(600px circle at ${e.clientX - rect.left}px ${e.clientY - rect.top}px, rgba(217,119,6,0.12), transparent 40%)`;
          }

          // Parallax floaters
          if (float1) float1.style.transform = `translate(${x * -30}px, ${y * -20}px)`;
          if (float2) float2.style.transform = `translate(${x * 20}px, ${y * -30}px)`;
          if (float3) float3.style.transform = `translate(${x * -15}px, ${y * 25}px)`;
        });

        heroVisual.addEventListener('mouseleave', () => {
          heroCard.style.transform = 'perspective(1200px) rotateY(0) rotateX(0) scale3d(1, 1, 1)';
          if (cardShine) cardShine.style.background = 'transparent';
          if (float1) float1.style.transform = 'translate(0, 0)';
          if (float2) float2.style.transform = 'translate(0, 0)';
          if (float3) float3.style.transform = 'translate(0, 0)';
        });
      }

      // Path cards 3D tilt
      document.querySelectorAll('[data-tilt]').forEach((card) => {
        card.addEventListener('mousemove', (e) => {
          const rect = card.getBoundingClientRect();
          const x = (e.clientX - rect.left) / rect.width - 0.5;
          const y = (e.clientY - rect.top) / rect.height - 0.5;

          card.querySelector('.hp-path-card__inner').style.transform =
            `perspective(800px) rotateY(${x * 12}deg) rotateX(${-y * 12}deg)`;

          const shine = card.querySelector('.hp-path-card__shine');
          if (shine) {
            shine.style.background =
              `radial-gradient(400px circle at ${e.clientX - rect.left}px ${e.clientY - rect.top}px, rgba(255,255,255,0.15), transparent 40%)`;
          }
        });

        card.addEventListener('mouseleave', () => {
          card.querySelector('.hp-path-card__inner').style.transform =
            'perspective(800px) rotateY(0deg) rotateX(0deg)';
          const shine = card.querySelector('.hp-path-card__shine');
          if (shine) shine.style.background = 'transparent';
        });
      });

      // Subtle tilt for content cards
      document.querySelectorAll('[data-tilt-subtle]').forEach((card) => {
        card.addEventListener('mousemove', (e) => {
          const rect = card.getBoundingClientRect();
          const x = (e.clientX - rect.left) / rect.width - 0.5;
          const y = (e.clientY - rect.top) / rect.height - 0.5;
          card.style.transform =
            `perspective(1000px) rotateY(${x * 5}deg) rotateX(${-y * 5}deg)`;
        });
        card.addEventListener('mouseleave', () => {
          card.style.transform = 'perspective(1000px) rotateY(0) rotateX(0)';
        });
      });

      // Hero orbs follow mouse (subtly)
      const hero = document.getElementById('hero');
      const orb1 = document.getElementById('orb1');
      const orb2 = document.getElementById('orb2');

      if (hero && orb1 && orb2) {
        hero.addEventListener('mousemove', (e) => {
          const x = e.clientX / window.innerWidth;
          const y = e.clientY / window.innerHeight;
          orb1.style.transform = `translate(${x * 40}px, ${y * 30}px)`;
          orb2.style.transform = `translate(${x * -30}px, ${y * -20}px)`;
        });
      }

      // Scroll parallax for featured image
      const featImg = document.getElementById('feat-img');
      if (featImg) {
        let ticking = false;
        window.addEventListener('scroll', () => {
          if (!ticking) {
            requestAnimationFrame(() => {
              const rect = featImg.getBoundingClientRect();
              const viewH = window.innerHeight;
              if (rect.top < viewH && rect.bottom > 0) {
                const progress = (viewH - rect.top) / (viewH + rect.height);
                featImg.style.transform = `scale(1.1) translateY(${(progress - 0.5) * -40}px)`;
              }
              ticking = false;
            });
            ticking = true;
          }
        }, { passive: true });
      }

      // Scroll-triggered section reveals
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('hp-visible');
              revealObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
      );

      document.querySelectorAll('.hp-paths, .hp-content, .hp-feed, .hp-cta').forEach((el) => {
        el.classList.add('hp-reveal');
        revealObserver.observe(el);
      });
    }
  </script>
</BaseLayout>

