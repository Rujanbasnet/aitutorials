---
import BaseLayout from '@layouts/BaseLayout.astro';
import PostCard from '@components/content/PostCard.astro';
import FeaturedPost from '@components/content/FeaturedPost.astro';
import { getPublishedBlog } from '@utils/collections';

const posts = await getPublishedBlog();
const featured = posts[0];
const rest = posts.slice(1);
---

<BaseLayout title="Blog" description="Opinions, reviews, guides, and insights about AI tools, workflows, and the future of technology.">

  <!-- Cinematic hero -->
  <section class="blog-hero relative overflow-hidden" style="background: var(--color-bg-dark);">
    <img
      src="/images/blog/scrolls.webp"
      alt="Ancient scrolls and manuscripts"
      class="absolute inset-0 w-full h-full object-cover opacity-60"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-[rgba(0,0,0,0.55)] via-[rgba(0,0,0,0.25)] to-transparent"></div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
      <p class="label mb-3 hero-label" style="color: var(--color-accent-soft);">Insights</p>
      <h1 class="text-title mb-3 hero-title" style="color: white;">Blog</h1>
      <p class="text-lg max-w-xl hero-subtitle" style="color: rgba(255,255,255,0.8);">
        Opinions, reviews, and deep dives into the AI ecosystem. What works, what doesn't, and why it matters.
      </p>

      <div class="flex flex-wrap items-center gap-4 mt-8">
        <div class="flex items-center gap-2 text-sm" style="color: rgba(255,255,255,0.6);">
          <div class="w-2 h-2 rounded-full pulse-dot" style="background: var(--color-accent-soft);"></div>
          {posts.length} posts
        </div>
        <div class="flex items-center gap-2 text-sm" style="color: rgba(255,255,255,0.6);">
          <div class="w-2 h-2 rounded-full pulse-dot" style="background: var(--color-sage-soft); animation-delay: 0.5s;"></div>
          Honest takes only
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    {posts.length > 0 ? (
      <>
        <!-- Featured latest post -->
        {featured && (
          <div class="mb-8 fade-in">
            <FeaturedPost
              title={featured.data.title}
              description={featured.data.description}
              href={`/blog/${featured.id}/`}
              pubDate={featured.data.pubDate}
              tags={featured.data.tags}
              image={featured.data.image}
              body={featured.body || ''}
              category={featured.data.category}
              collection="blog"
            />
          </div>
        )}

        {rest.length > 0 && (
          <>
            <div class="flex items-center gap-3 mb-8">
              <h2 class="text-heading">More posts</h2>
              <div class="flex-1 h-px bg-[var(--color-border)]"></div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger">
              {rest.map((post) => (
                <div class="fade-in">
                  <PostCard
                    title={post.data.title}
                    description={post.data.description}
                    href={`/blog/${post.id}/`}
                    pubDate={post.data.pubDate}
                    tags={post.data.tags}
                    image={post.data.image}
                    body={post.body || ''}
                    category={post.data.category}
                    collection="blog"
                  />
                </div>
              ))}
            </div>
          </>
        )}
      </>
    ) : (
      <div class="card-warm p-16 text-center rounded-xl">
        <h3 class="text-heading mb-2">Coming soon</h3>
        <p class="text-[var(--color-text-secondary)]">Blog posts are being written. Check back soon.</p>
      </div>
    )}
  </section>

  <!-- CTA -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 text-center">
    <div class="cta-card card-warm p-8 sm:p-10 rounded-xl relative overflow-hidden">
      <div class="cta-glow"></div>
      <h3 class="text-heading mb-3 relative">Prefer learning by doing?</h3>
      <p class="text-[var(--color-text-secondary)] mb-6 max-w-md mx-auto relative">Our tutorials walk you through real AI workflows step by step. Or try a challenge and build something in 2 minutes.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 relative">
        <a href="/tutorials/" class="inline-flex items-center px-6 py-3 rounded-full bg-[var(--color-text-primary)] text-white font-medium hover:bg-[var(--color-text-secondary)] transition-colors text-sm">
          Browse tutorials
        </a>
        <a href="/challenges/" class="inline-flex items-center px-6 py-3 rounded-full border border-[var(--color-border)] text-[var(--color-text-secondary)] font-medium hover:border-[var(--color-border-strong)] transition-colors text-sm">
          Try a challenge
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .pulse-dot {
    animation: pulse-ring 3s ease-in-out infinite;
  }
  @keyframes pulse-ring {
    0%, 100% { box-shadow: 0 0 0 0 currentColor; opacity: 1; }
    50%      { box-shadow: 0 0 0 4px transparent; opacity: 0.7; }
  }

  .hero-label {
    animation: slide-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .hero-title {
    animation: slide-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }
  .hero-subtitle {
    animation: slide-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;
  }
  @keyframes slide-up {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .cta-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, var(--color-accent-soft) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.5s;
  }
  .cta-card:hover .cta-glow {
    opacity: 0.5;
  }

  @media (prefers-reduced-motion: reduce) {
    .pulse-dot,
    .hero-label,
    .hero-title,
    .hero-subtitle { animation: none; }
  }
</style>
