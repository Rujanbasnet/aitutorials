---
import BaseLayout from '@layouts/BaseLayout.astro';
import PostCard from '@components/content/PostCard.astro';
import { getPublishedBlog } from '@utils/collections';

const posts = await getPublishedBlog();
---

<BaseLayout title="Blog" description="Opinions, reviews, guides, and insights about AI tools, workflows, and the future of technology.">
  <section class="relative overflow-hidden" style="background: var(--color-bg-dark);">
    <img
      src="/images/blog/scrolls.jpg"
      alt="Ancient scrolls and manuscripts"
      class="absolute inset-0 w-full h-full object-cover opacity-60"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-[rgba(20,20,19,0.7)] via-[rgba(20,20,19,0.3)] to-transparent"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
      <p class="label mb-3" style="color: var(--color-accent-soft);">Insights</p>
      <h1 class="text-title mb-3" style="color: white;">Blog</h1>
      <p class="text-lg max-w-xl" style="color: rgba(255,255,255,0.75);">
        Opinions, reviews, and deep dives into the AI ecosystem.
      </p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger">
        {posts.map((post) => (
          <div class="fade-in">
            <PostCard
              title={post.data.title}
              description={post.data.description}
              href={`/blog/${post.id}/`}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              image={post.data.image}
              body={post.body || ''}
              category={post.data.category}
              collection="blog"
            />
          </div>
        ))}
      </div>
    ) : (
      <div class="card-warm p-16 text-center rounded-xl">
        <h3 class="text-heading mb-2">Coming soon</h3>
        <p class="text-[var(--color-text-secondary)]">Blog posts are being written. Check back soon.</p>
      </div>
    )}
  </section>
</BaseLayout>
