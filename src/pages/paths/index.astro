---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getLearningPathsWithTime, getTutorialsForPath } from '@utils/collections';

const paths = await getLearningPathsWithTime();

// Get tutorial details for each path
const pathsWithTutorials = await Promise.all(
  paths.map(async (path) => {
    const tutorials = await getTutorialsForPath(path.id);
    return { ...path, tutorials };
  })
);
---

<BaseLayout title="Learning Paths" description="Guided step-by-step learning journeys to build your AI skills from beginner to advanced.">

  <!-- Hero -->
  <section class="relative overflow-hidden bg-warm">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, var(--color-text-primary) 1px, transparent 0); background-size: 24px 24px;"></div>
    <canvas class="paths-canvas" id="paths-canvas" aria-hidden="true"></canvas>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
      <p class="label mb-3">Learn</p>
      <h1 class="text-title mb-3">Learning Paths</h1>
      <p class="text-lg text-[var(--color-text-secondary)] max-w-xl">
        Don't know where to start? Pick a path and follow it step by step. Each one takes you from A to Z on a specific topic.
      </p>
    </div>
  </section>

  <!-- Paths -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="space-y-8">
      {pathsWithTutorials.map((path) => (
        <a href={`/paths/${path.id}/`} class="group block">
          <div class="bg-[var(--color-bg-card)] border-2 border-[var(--color-border)] rounded-2xl p-8 hover:border-[var(--color-border-strong)] hover:shadow-lg transition-all duration-300 hover:-translate-y-0.5">
            {/* Color bar */}
            <div style={`width: 100%; height: 6px; border-radius: 3px; margin-bottom: 1.5rem; background: linear-gradient(90deg, ${path.id === 'ai-foundations' ? 'var(--color-sage), var(--color-accent)' : 'var(--color-accent), var(--color-clay)'});`}></div>

            <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6">
              <div class="flex-1">
                <span class:list={[
                  'text-xs font-semibold px-2.5 py-0.5 rounded-sm uppercase tracking-wider inline-block mb-3',
                  path.difficulty === 'beginner' ? 'badge-beginner' : 'badge-intermediate',
                ]}>
                  {path.difficulty}
                </span>

                <h2 class="text-2xl text-[var(--color-text-primary)] mb-2 group-hover:text-[var(--color-accent)] transition-colors" style="font-family: var(--font-display);">
                  {path.title}
                </h2>

                <p class="text-[var(--color-text-secondary)] leading-relaxed mb-4">
                  {path.description}
                </p>

                <p class="text-sm text-[var(--color-text-muted)]">
                  {path.stepCount} tutorials &middot; {path.totalTime}
                </p>
              </div>

              {/* Step list preview */}
              <div class="md:w-64 shrink-0">
                <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-3">Steps</p>
                <ol class="space-y-2">
                  {path.tutorials.slice(0, 4).map((tutorial, i) => (
                    <li class="flex items-center gap-3 text-sm">
                      <span class="w-6 h-6 rounded-full bg-[var(--color-bg-warm)] text-[var(--color-text-muted)] flex items-center justify-center text-xs font-medium shrink-0">
                        {i + 1}
                      </span>
                      <span class="text-[var(--color-text-secondary)] line-clamp-1">
                        {tutorial.data.title.split(':')[0]}
                      </span>
                    </li>
                  ))}
                  {path.tutorials.length > 4 && (
                    <li class="text-xs text-[var(--color-text-muted)] pl-9">
                      +{path.tutorials.length - 4} more
                    </li>
                  )}
                </ol>
              </div>
            </div>

            <div class="mt-6 text-sm font-medium text-[var(--color-accent)] group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">
              Start this path
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-12 text-center">
      <p class="text-[var(--color-text-muted)] mb-4">Not sure which path to choose?</p>
      <a href="/start/" class="inline-flex items-center gap-2 px-6 py-2.5 rounded-full bg-[var(--color-text-primary)] text-white text-sm font-medium hover:bg-[var(--color-text-secondary)] transition-colors">
        Take the Start Here quiz
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
.paths-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  pointer-events: none;
}
@media (prefers-reduced-motion: reduce) {
  .paths-canvas { display: none !important; }
}
</style>

<script is:inline>
(function() {
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  const canvas = document.getElementById('paths-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const hero = canvas.closest('section');

  function resize() {
    const rect = hero.getBoundingClientRect();
    canvas.width = rect.width * devicePixelRatio;
    canvas.height = rect.height * devicePixelRatio;
    canvas.style.width = rect.width + 'px';
    canvas.style.height = rect.height + 'px';
    ctx.setTransform(devicePixelRatio, 0, 0, devicePixelRatio, 0, 0);
  }

  const isMobile = window.innerWidth < 768;
  const colors = {
    root: 'rgba(217, 119, 6, 0.5)',
    level2: 'rgba(45, 106, 79, 0.45)',
    level3: 'rgba(120, 53, 15, 0.4)',
    branch: 'rgba(180, 100, 20, 0.15)',
    branchGlow: 'rgba(180, 100, 20, 0.35)',
    pulse: 'rgba(217, 119, 6, 0.6)',
  };

  // Build tree
  var nodes = [];
  var branches = [];

  function buildTree() {
    nodes = [];
    branches = [];
    var w = hero.getBoundingClientRect().width;
    var h = hero.getBoundingClientRect().height;
    var rootX = isMobile ? w * 0.5 : w * 0.75;
    var rootY = h * 0.2;
    var vSpacing = 60;
    var hSpread = 80;

    var id = 0;
    // Root
    nodes.push({ id: id++, x: rootX, y: rootY, baseX: rootX, baseY: rootY, r: 6, level: 0, phase: Math.random() * Math.PI * 2, phaseY: Math.random() * Math.PI * 2, children: [] });

    // Level 2
    var l2Count = isMobile ? 3 : 3;
    var l2Start = rootX - hSpread * (l2Count - 1) / 2;
    for (var i = 0; i < l2Count; i++) {
      var nx = l2Start + i * hSpread;
      var ny = rootY + vSpacing;
      var node = { id: id++, x: nx, y: ny, baseX: nx, baseY: ny, r: 5, level: 1, phase: Math.random() * Math.PI * 2, phaseY: Math.random() * Math.PI * 2, children: [] };
      nodes.push(node);
      nodes[0].children.push(node.id);
      branches.push({ from: 0, to: node.id });
    }

    // Level 3 (skip on mobile)
    if (!isMobile) {
      for (var j = 1; j <= l2Count; j++) {
        var parent = nodes[j];
        var cCount = 2;
        var cStart = parent.baseX - hSpread * 0.4 * (cCount - 1) / 2;
        for (var k = 0; k < cCount; k++) {
          var cx = cStart + k * hSpread * 0.4;
          var cy = parent.baseY + vSpacing;
          var cnode = { id: id++, x: cx, y: cy, baseX: cx, baseY: cy, r: 4, level: 2, phase: Math.random() * Math.PI * 2, phaseY: Math.random() * Math.PI * 2, children: [] };
          nodes.push(cnode);
          parent.children.push(cnode.id);
          branches.push({ from: parent.id, to: cnode.id });

          // Level 4 (a few extra leaves for density)
          if (k === 0 || (j === 2 && k === 1)) {
            var lx = cx + (Math.random() - 0.5) * hSpread * 0.3;
            var ly = cy + vSpacing * 0.8;
            var leaf = { id: id++, x: lx, y: ly, baseX: lx, baseY: ly, r: 3.5, level: 3, phase: Math.random() * Math.PI * 2, phaseY: Math.random() * Math.PI * 2, children: [] };
            nodes.push(leaf);
            cnode.children.push(leaf.id);
            branches.push({ from: cnode.id, to: leaf.id });
          }
        }
      }
    }
  }

  // Pulse state
  var pulse = { active: false, path: [], progress: 0, startTime: 0 };
  var lastPulseTime = 0;
  var pulseInterval = 4000;
  var pulseDuration = 1500;

  function pickRandomPath() {
    var path = [0];
    var current = nodes[0];
    while (current.children.length > 0) {
      var next = current.children[Math.floor(Math.random() * current.children.length)];
      path.push(next);
      current = nodes[next];
    }
    return path;
  }

  // Mouse
  var mouseX = -9999, mouseY = -9999;
  hero.addEventListener('mousemove', function(e) {
    var rect = hero.getBoundingClientRect();
    mouseX = e.clientX - rect.left;
    mouseY = e.clientY - rect.top;
  });
  hero.addEventListener('mouseleave', function() {
    mouseX = -9999;
    mouseY = -9999;
  });

  function nodeColor(level, bright) {
    if (bright) {
      if (level === 0) return 'rgba(217, 119, 6, 0.8)';
      if (level === 1) return 'rgba(45, 106, 79, 0.75)';
      return 'rgba(120, 53, 15, 0.7)';
    }
    if (level === 0) return colors.root;
    if (level === 1) return colors.level2;
    return colors.level3;
  }

  function draw(time) {
    if (!ctx) return;
    var rect = hero.getBoundingClientRect();
    ctx.clearRect(0, 0, rect.width, rect.height);

    // Animate node positions
    var amp = 5;
    var speed = 0.0008;
    for (var i = 0; i < nodes.length; i++) {
      var n = nodes[i];
      n.x = n.baseX + Math.sin(time * speed + n.phase) * amp;
      n.y = n.baseY + Math.sin(time * speed * 0.7 + n.phaseY) * amp * 0.6;
    }

    // Check proximity to mouse
    var nearSet = new Set();
    var nearBranches = new Set();
    for (var i = 0; i < nodes.length; i++) {
      var n = nodes[i];
      var dx = n.x - mouseX;
      var dy = n.y - mouseY;
      if (Math.sqrt(dx * dx + dy * dy) < 80) {
        nearSet.add(n.id);
      }
    }
    // Mark branches connected to near nodes
    for (var i = 0; i < branches.length; i++) {
      if (nearSet.has(branches[i].from) || nearSet.has(branches[i].to)) {
        nearBranches.add(i);
      }
    }

    // Draw branches
    for (var i = 0; i < branches.length; i++) {
      var b = branches[i];
      var from = nodes[b.from];
      var to = nodes[b.to];
      var cpx = (from.x + to.x) / 2 + (to.x - from.x) * 0.15;
      var cpy = (from.y + to.y) / 2;
      ctx.beginPath();
      ctx.moveTo(from.x, from.y);
      ctx.quadraticCurveTo(cpx, cpy, to.x, to.y);
      ctx.strokeStyle = nearBranches.has(i) ? colors.branchGlow : colors.branch;
      ctx.lineWidth = 1.5;
      ctx.stroke();
    }

    // Draw nodes
    for (var i = 0; i < nodes.length; i++) {
      var n = nodes[i];
      var bright = nearSet.has(n.id);
      ctx.beginPath();
      ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
      ctx.fillStyle = nodeColor(n.level, bright);
      ctx.fill();
    }

    // Pulse logic
    if (!pulse.active && time - lastPulseTime > pulseInterval) {
      pulse.active = true;
      pulse.path = pickRandomPath();
      pulse.startTime = time;
      lastPulseTime = time;
    }

    if (pulse.active) {
      var elapsed = time - pulse.startTime;
      var t = elapsed / pulseDuration;
      if (t >= 1) {
        pulse.active = false;
      } else {
        // Find position along path
        var totalSegs = pulse.path.length - 1;
        if (totalSegs > 0) {
          var segFloat = t * totalSegs;
          var segIdx = Math.min(Math.floor(segFloat), totalSegs - 1);
          var segT = segFloat - segIdx;
          var from = nodes[pulse.path[segIdx]];
          var to = nodes[pulse.path[segIdx + 1]];
          var cpx = (from.x + to.x) / 2 + (to.x - from.x) * 0.15;
          var cpy = (from.y + to.y) / 2;
          // Quadratic bezier point at segT
          var px = (1 - segT) * (1 - segT) * from.x + 2 * (1 - segT) * segT * cpx + segT * segT * to.x;
          var py = (1 - segT) * (1 - segT) * from.y + 2 * (1 - segT) * segT * cpy + segT * segT * to.y;
          ctx.beginPath();
          ctx.arc(px, py, 3, 0, Math.PI * 2);
          ctx.fillStyle = colors.pulse;
          ctx.fill();
        }
      }
    }

    requestAnimationFrame(draw);
  }

  resize();
  buildTree();
  window.addEventListener('resize', function() {
    resize();
    buildTree();
  });
  requestAnimationFrame(draw);
})();
</script>
