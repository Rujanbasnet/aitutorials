---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description} image={entry.data.image}>

  <!-- Product JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": entry.data.title,
    "description": entry.data.description,
    "offers": {
      "@type": "Offer",
      "price": entry.data.price,
      "priceCurrency": entry.data.currency,
      "availability": "https://schema.org/InStock",
      "url": entry.data.gumroadUrl,
    },
    ...(entry.data.image ? { "image": entry.data.image } : {}),
  })} />

  <!-- BreadcrumbList JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://aitutorials.com.au/" },
      { "@type": "ListItem", "position": 2, "name": "Products", "item": "https://aitutorials.com.au/products/" },
      { "@type": "ListItem", "position": 3, "name": entry.data.title }
    ]
  })} />

  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">

    <!-- Breadcrumb -->
    <nav class="mb-8 text-sm text-[var(--color-text-muted)]">
      <a href="/" class="hover:text-[var(--color-text-primary)] transition-colors">Home</a>
      <span class="mx-2 opacity-40">/</span>
      <a href="/products/" class="hover:text-[var(--color-text-primary)] transition-colors">Products</a>
    </nav>

    <!-- Header -->
    <header class="mb-12">
      <div class="flex flex-wrap gap-2 mb-5">
        <span class="badge-intermediate text-xs font-semibold px-2.5 py-0.5 rounded-sm uppercase tracking-wide">
          {entry.data.productType.replace('-', ' ')}
        </span>
        {entry.data.tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>

      <h1 class="text-display mb-5">{entry.data.title}</h1>
      <p class="text-lg text-[var(--color-text-secondary)] mb-8 leading-relaxed max-w-2xl">{entry.data.description}</p>

      <!-- Price + CTA -->
      <div class="flex flex-wrap items-center gap-4 pb-8 border-b border-[var(--color-border)]">
        <span class="text-2xl font-semibold text-[var(--color-text-primary)]" style="font-family: var(--font-display)">
          {entry.data.price === 0 ? 'Free' : `$${entry.data.price} ${entry.data.currency}`}
        </span>
        <a
          href={entry.data.gumroadUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-[var(--color-accent)] text-white font-medium hover:bg-[var(--color-accent-hover)] transition-colors text-sm"
        >
          {entry.data.price === 0 ? 'Get it free' : 'Buy on Gumroad'}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
          </svg>
        </a>
      </div>
    </header>

    {entry.data.image && (
      <div class="mb-12 rounded-xl overflow-hidden border border-[var(--color-border)]">
        <img src={entry.data.image} alt={entry.data.title} class="w-full h-auto" loading="lazy" />
      </div>
    )}

    <!-- Content -->
    <div class="prose max-w-none">
      <Content />
    </div>

    <!-- Bottom CTA -->
    <div class="mt-16 pt-10 border-t border-[var(--color-border)]">
      <div class="card-warm p-8 sm:p-10 text-center rounded-xl">
        <h3 class="text-heading mb-3">{entry.data.title}</h3>
        <p class="text-[var(--color-text-secondary)] mb-6">{entry.data.description}</p>
        <a
          href={entry.data.gumroadUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-[var(--color-accent)] text-white font-medium hover:bg-[var(--color-accent-hover)] transition-colors"
        >
          {entry.data.price === 0 ? 'Get it free' : `Buy for $${entry.data.price}`}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
          </svg>
        </a>
      </div>
    </div>

  </article>
</BaseLayout>
