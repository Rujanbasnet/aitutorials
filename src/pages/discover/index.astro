---
import BaseLayout from '@layouts/BaseLayout.astro';
import ToolCard from '@components/content/ToolCard.astro';
import tools from '@data/tools.json';
import { getPublishedProducts } from '@utils/collections';

const products = await getPublishedProducts();

// Use-case journeys — organized by what you want to accomplish
const journeys = [
  {
    id: 'talk',
    question: 'I want to talk to AI',
    description: 'Your AI conversation partner for questions, brainstorming, writing help, and more.',
    icon: 'chat',
    color: 'var(--color-sage)',
    colorSoft: 'var(--color-sage-soft)',
    recommend: 'Claude',
    recommendWhy: 'Best for thoughtful, nuanced conversations',
    categories: ['Chatbots'],
  },
  {
    id: 'research',
    question: 'I want to research smarter',
    description: 'AI tools that search the web, read documents, and cite their sources.',
    icon: 'search',
    color: 'var(--color-accent)',
    colorSoft: 'var(--color-accent-soft)',
    recommend: 'Perplexity',
    recommendWhy: 'Like Google but gives you actual answers with sources',
    categories: ['Research'],
  },
  {
    id: 'images',
    question: 'I want to create images',
    description: 'Turn text descriptions into stunning artwork, photos, logos, and designs.',
    icon: 'image',
    color: 'var(--color-clay)',
    colorSoft: 'var(--color-clay-soft)',
    recommend: 'DALL-E 3',
    recommendWhy: 'Included free with ChatGPT -- easiest way to start',
    categories: ['Image'],
  },
  {
    id: 'media',
    question: 'I want to make videos & audio',
    description: 'Generate voiceovers, music, edit video -- all powered by AI.',
    icon: 'media',
    color: 'var(--color-accent)',
    colorSoft: 'var(--color-accent-soft)',
    recommend: 'ElevenLabs',
    recommendWhy: 'Eerily realistic voices from text -- free tier is generous',
    categories: ['Audio', 'Video'],
  },
  {
    id: 'build',
    question: 'I want to build apps & websites',
    description: 'From code editors to full app builders -- AI that writes code for you.',
    icon: 'code',
    color: 'var(--color-sage)',
    colorSoft: 'var(--color-sage-soft)',
    recommend: 'Bolt',
    recommendWhy: 'Describe an app, get a working prototype in seconds',
    categories: ['Coding'],
  },
  {
    id: 'create',
    question: 'I want to design & present',
    description: 'Create presentations, graphics, and designs without being a designer.',
    icon: 'design',
    color: 'var(--color-clay)',
    colorSoft: 'var(--color-clay-soft)',
    recommend: 'Gamma',
    recommendWhy: 'Makes beautiful slides from a single sentence',
    categories: ['Productivity'],
  },
  {
    id: 'write',
    question: 'I want to write better',
    description: 'Generate marketing copy, blog posts, emails, and social media content.',
    icon: 'write',
    color: 'var(--color-accent)',
    colorSoft: 'var(--color-accent-soft)',
    recommend: 'Copy.ai',
    recommendWhy: 'Purpose-built for marketing and business writing',
    categories: ['Writing'],
  },
  {
    id: 'automate',
    question: 'I want to automate tasks',
    description: 'Connect your apps and build workflows that run on autopilot.',
    icon: 'zap',
    color: 'var(--color-sage)',
    colorSoft: 'var(--color-sage-soft)',
    recommend: 'Make',
    recommendWhy: 'Visual builder -- no coding needed, generous free tier',
    categories: ['Automation'],
  },
];

// Map tools to journeys
const journeysWithTools = journeys.map(j => ({
  ...j,
  tools: tools.filter(t => j.categories.includes(t.category)),
}));

const trendingCount = tools.filter(t => t.trending).length;
const newCount = tools.filter(t => t.new).length;

// SVG icons for each journey
const icons: Record<string, string> = {
  chat: '<path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" />',
  search: '<path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />',
  image: '<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M2.25 18V6a2.25 2.25 0 012.25-2.25h15A2.25 2.25 0 0121.75 6v12A2.25 2.25 0 0119.5 20.25H4.5A2.25 2.25 0 012.25 18z" />',
  media: '<path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 010 1.972l-11.54 6.347a1.125 1.125 0 01-1.667-.986V5.653z" />',
  code: '<path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />',
  design: '<path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42" />',
  write: '<path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />',
  zap: '<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />',
};

// Starter kit -- the 3 tools every beginner should know
const starterKit = [
  { name: 'ChatGPT', why: 'Your first AI conversation', tool: tools.find(t => t.name === 'ChatGPT')! },
  { name: 'Perplexity', why: 'AI-powered search', tool: tools.find(t => t.name === 'Perplexity')! },
  { name: 'Canva AI', why: 'Design anything visually', tool: tools.find(t => t.name === 'Canva AI')! },
];
---

<BaseLayout
  title="AI Tools & Products"
  description="Not sure which AI tool to use? Tell us what you want to do and we'll point you to the right one. Plus digital products to accelerate your AI workflow."
>

  <!-- Hero -- warm editorial -->
  <section class="tools-hero">
    <div class="tools-hero__bg" aria-hidden="true">
      <div class="tools-hero__texture"></div>
      <div class="tools-hero__gradient"></div>
      <canvas class="tools-hero__canvas" id="tools-canvas"></canvas>
    </div>

    <div class="tools-hero__inner">
      <a href="/" class="tools-hero__back hero-label">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        Home
      </a>
      <h1 class="tools-hero__title hero-title">
        AI Tools<br />
        <span class="tools-hero__accent">& Products</span>
      </h1>
      <p class="tools-hero__sub hero-subtitle">
        Pick what you're trying to accomplish and we'll show you the best tools. Plus digital products built from real AI workflows.
      </p>

      <div class="tools-hero__stats">
        <div class="flex items-center gap-2">
          <div class="w-2 h-2 rounded-full" style="background: var(--color-sage);"></div>
          <span><strong>{tools.length}</strong> tools curated</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="w-2 h-2 rounded-full" style="background: var(--color-accent);"></div>
          <span><strong>{trendingCount}</strong> trending</span>
        </div>
        <div class="flex items-center gap-2">
          <div class="w-2 h-2 rounded-full" style="background: var(--color-clay);"></div>
          <span>All tested by us</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Jump -- "What do you want to do?" buttons -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 -mt-6 relative z-10">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      {journeysWithTools.map((j) => (
        <a
          href={`#${j.id}`}
          class="quick-jump group flex flex-col items-center gap-2 p-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-card)] hover:border-[var(--color-border-strong)] hover:shadow-md transition-all duration-300"
        >
          <div class="w-10 h-10 rounded-lg flex items-center justify-center transition-transform group-hover:scale-110" style={`background: ${j.colorSoft};`}>
            <svg class="w-5 h-5" style={`color: ${j.color};`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" set:html={icons[j.icon]} />
          </div>
          <span class="text-xs font-medium text-[var(--color-text-secondary)] text-center leading-tight group-hover:text-[var(--color-text-primary)] transition-colors">
            {j.question.replace('I want to ', '')}
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- Starter Kit -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="starter-kit card-warm rounded-2xl p-6 sm:p-8 relative overflow-hidden">
      <div class="starter-glow"></div>
      <div class="relative">
        <div class="flex items-center gap-3 mb-2">
          <span class="text-xs font-bold uppercase tracking-wider px-2.5 py-1 rounded-sm bg-[var(--color-sage-soft)] text-[var(--color-sage)]">
            Recommended
          </span>
          <span class="text-xs text-[var(--color-text-muted)]">Perfect for beginners</span>
        </div>
        <h2 class="text-heading mb-2">Not sure where to start?</h2>
        <p class="text-sm text-[var(--color-text-secondary)] mb-6 max-w-lg">
          These 3 tools cover 80% of what most people need. Start here, then explore the rest when you're ready.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {starterKit.map((item, i) => (
            <a
              href={item.tool.url}
              target="_blank"
              rel="noopener nofollow"
              class="group/starter flex items-start gap-3 p-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] hover:border-[var(--color-border-strong)] hover:shadow-sm transition-all"
            >
              <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0 text-lg font-semibold" style={`background: var(--color-${i === 0 ? 'sage' : i === 1 ? 'accent' : 'clay'}-soft); color: var(--color-${i === 0 ? 'sage' : i === 1 ? 'accent' : 'clay'}); font-family: var(--font-display);`}>
                {i + 1}
              </div>
              <div class="min-w-0">
                <h3 class="text-sm font-semibold text-[var(--color-text-primary)] group-hover/starter:text-[var(--color-accent)] transition-colors">
                  {item.name}
                </h3>
                <p class="text-xs text-[var(--color-text-muted)] mt-0.5">{item.why}</p>
                <p class="text-[0.65rem] mt-1" style={`color: var(--color-${i === 0 ? 'sage' : i === 1 ? 'accent' : 'clay'});`}>
                  {item.tool.pricingDetail}
                </p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Affiliate Disclosure -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <p class="text-xs text-[var(--color-text-muted)] italic">
      Some links on this page may be affiliate links. We only recommend tools we genuinely find useful.
    </p>
  </div>

  <!-- Journey Sections -->
  {journeysWithTools.map((j, idx) => (
    <section id={j.id} class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10 lg:py-12 journey-section">
      {/* Section header */}
      <div class="flex items-start gap-4 mb-6">
        <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0" style={`background: ${j.colorSoft};`}>
          <svg class="w-6 h-6" style={`color: ${j.color};`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" set:html={icons[j.icon]} />
        </div>
        <div>
          <h2 class="text-xl text-[var(--color-text-primary)] mb-1" style="font-family: var(--font-display);">
            {j.question}
          </h2>
          <p class="text-sm text-[var(--color-text-secondary)]">{j.description}</p>
        </div>
      </div>

      {/* "Start with" recommendation */}
      <div class="recommend-card flex items-center gap-3 mb-6 p-3 rounded-lg border border-dashed" style={`border-color: ${j.color}40;`}>
        <div class="w-6 h-6 rounded-full flex items-center justify-center shrink-0" style={`background: ${j.colorSoft};`}>
          <svg class="w-3.5 h-3.5" style={`color: ${j.color};`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.562.562 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
          </svg>
        </div>
        <div class="text-sm">
          <span class="text-[var(--color-text-muted)]">Start with</span>
          <span class="font-semibold text-[var(--color-text-primary)] ml-1">{j.recommend}</span>
          <span class="text-[var(--color-text-muted)] ml-1">-- {j.recommendWhy}</span>
        </div>
      </div>

      {/* Tool cards */}
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {j.tools.map((tool) => (
          <ToolCard
            name={tool.name}
            description={tool.description}
            category={tool.category}
            url={tool.url}
            affiliateUrl={tool.affiliateUrl}
            pricing={tool.pricing}
            pricingDetail={tool.pricingDetail}
            trending={tool.trending}
            new={tool.new}
            image={tool.image}
          />
        ))}
      </div>

      {/* Divider between sections (not after last) */}
      {idx < journeysWithTools.length - 1 && (
        <div class="mt-10 flex items-center gap-4">
          <div class="flex-1 h-px bg-[var(--color-border)]"></div>
          <svg class="w-4 h-4 text-[var(--color-text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5L12 21m0 0l-7.5-7.5M12 21V3" />
          </svg>
          <div class="flex-1 h-px bg-[var(--color-border)]"></div>
        </div>
      )}
    </section>
  ))}

  <!-- Digital Products Section -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10 lg:py-12">
    <div class="flex items-center gap-4 mb-8">
      <div class="flex-1 h-px bg-[var(--color-border)]"></div>
      <h2 class="text-xl text-[var(--color-text-primary)] shrink-0" style="font-family: var(--font-display);">Digital Products</h2>
      <div class="flex-1 h-px bg-[var(--color-border)]"></div>
    </div>
    <p class="text-sm text-[var(--color-text-secondary)] text-center mb-8 max-w-lg mx-auto">
      Templates, guides, and resources built from real AI workflows. No fluff -- just what works.
    </p>

    {products.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger">
        {products.map((product) => (
          <div class="fade-in">
            <a href={`/products/${product.id}/`} class="card-accent block overflow-hidden group">
              {product.data.image && (
                <div class="aspect-video overflow-hidden">
                  <img
                    src={product.data.image}
                    alt={product.data.title}
                    class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700 ease-out"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="p-5 sm:p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="badge-intermediate text-xs font-semibold px-2.5 py-0.5 rounded-sm uppercase tracking-wide">
                    {product.data.productType.replace('-', ' ')}
                  </span>
                  {product.data.featured && (
                    <span class="badge-beginner text-xs font-semibold px-2.5 py-0.5 rounded-sm uppercase tracking-wide">
                      Featured
                    </span>
                  )}
                </div>
                <h3 class="text-lg text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)] transition-colors mb-2" style="font-family: var(--font-display)">
                  {product.data.title}
                </h3>
                <p class="text-sm text-[var(--color-text-secondary)] line-clamp-2 mb-4 leading-relaxed">
                  {product.data.description}
                </p>
                <div class="flex items-center justify-between">
                  <span class="text-lg font-semibold text-[var(--color-text-primary)]">
                    {product.data.price === 0 ? 'Free' : `$${product.data.price}`}
                  </span>
                  <span class="text-sm text-[var(--color-accent)] font-medium">
                    View details &rarr;
                  </span>
                </div>
              </div>
            </a>
          </div>
        ))}
      </div>
    ) : (
      <div class="card-warm p-16 text-center rounded-xl">
        <h3 class="text-heading mb-2">Coming soon</h3>
        <p class="text-[var(--color-text-secondary)] mb-6">Products are being prepared. Check back soon or subscribe to get notified.</p>
        <a
          href="/newsletter/"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-[var(--color-text-primary)] text-white text-sm font-medium hover:bg-[var(--color-text-secondary)] transition-colors"
        >
          Subscribe for updates
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    )}
  </section>

  <!-- CTA -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 pb-16">
    <div class="cta-card card-warm rounded-xl p-8 sm:p-10 text-center relative overflow-hidden">
      <div class="cta-glow"></div>
      <div class="relative">
        <h3 class="text-heading mb-3">Ready to learn how to use them?</h3>
        <p class="text-[var(--color-text-secondary)] mb-6 max-w-md mx-auto">
          Tools are just the beginning. Our tutorials teach you how to get real results from AI.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          <a href="/paths/ai-foundations/" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-[var(--color-text-primary)] text-white text-sm font-medium hover:bg-[var(--color-text-secondary)] transition-colors">
            Start the AI Foundations path
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a href="/challenges/" class="inline-flex items-center px-6 py-3 rounded-full border border-[var(--color-border)] text-[var(--color-text-secondary)] text-sm font-medium hover:border-[var(--color-border-strong)] transition-colors">
            Or try a challenge first
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* -- Tools Hero -------------------------------- */
  .tools-hero {
    position: relative;
    overflow: hidden;
    background: #F8F5F0;
    text-align: center;
  }
  .tools-hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .tools-hero__texture {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    opacity: 0.03;
  }
  .tools-hero__gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 50% 50% at 50% 80%, var(--color-accent-soft) 0%, transparent 50%),
      radial-gradient(ellipse 40% 40% at 20% 20%, var(--color-sage-soft) 0%, transparent 50%),
      radial-gradient(ellipse 40% 40% at 80% 30%, var(--color-clay-soft) 0%, transparent 50%);
    opacity: 0.5;
  }
  .tools-hero__inner {
    position: relative;
    max-width: 48rem;
    margin: 0 auto;
    padding: 4rem clamp(20px, 5vw, 48px) 5rem;
  }
  .tools-hero__back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-bottom: 24px;
    transition: color 0.2s;
  }
  .tools-hero__back:hover { color: var(--color-accent); }
  .tools-hero__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 2rem + 3vw, 4.5rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--color-text-primary);
    margin-bottom: 16px;
  }
  .tools-hero__accent {
    color: var(--color-accent);
    font-style: italic;
  }
  .tools-hero__sub {
    font-size: clamp(0.9375rem, 0.85rem + 0.4vw, 1.0625rem);
    line-height: 1.7;
    color: var(--color-text-secondary);
    max-width: 32rem;
    margin: 0 auto;
  }
  .tools-hero__stats {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 20px;
    margin-top: 28px;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }
  .tools-hero__stats strong {
    color: var(--color-text-primary);
  }

  /* -- Hero animations -------------------------- */
  .hero-label {
    animation: slide-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .hero-title {
    animation: slide-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }
  .hero-subtitle {
    animation: slide-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;
  }
  @keyframes slide-up {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* -- Quick jump cards ------------------------- */
  .quick-jump {
    backdrop-filter: blur(8px);
  }
  .quick-jump:hover {
    transform: translateY(-2px);
  }

  /* -- Starter kit glow ------------------------- */
  .starter-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 30% 0%, var(--color-sage-soft) 0%, transparent 50%);
    opacity: 0.4;
  }

  /* -- Journey sections smooth scroll ----------- */
  .journey-section {
    scroll-margin-top: 2rem;
  }

  /* -- Recommend card --------------------------- */
  .recommend-card {
    background: var(--color-bg-warm);
  }

  /* -- CTA glow --------------------------------- */
  .cta-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, var(--color-accent-soft) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.5s;
  }
  .cta-card:hover .cta-glow {
    opacity: 0.5;
  }

  /* -- Hexagon canvas --------------------------- */
  .tools-hero__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }

  /* -- Reduced motion --------------------------- */
  @media (prefers-reduced-motion: reduce) {
    .hero-label,
    .hero-title,
    .hero-subtitle,
    .pulse-dot { animation: none; }
    .quick-jump { transition: none; }
    .tools-hero__canvas { display: none !important; }
  }
</style>

<script is:inline>
  // Smooth scroll for quick jump links
  document.querySelectorAll('.quick-jump').forEach(link => {
    link.addEventListener('click', (e) => {
      const href = link.getAttribute('href');
      if (href && href.startsWith('#')) {
        e.preventDefault();
        const target = document.querySelector(href);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }
    });
  });
</script>

<script is:inline>
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    var canvas = document.getElementById('tools-canvas');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    if (!ctx) return;

    var hero = document.querySelector('.tools-hero');
    if (!hero) return;

    var mouseX = -9999, mouseY = -9999;
    hero.addEventListener('mousemove', function (e) {
      var rect = hero.getBoundingClientRect();
      mouseX = e.clientX - rect.left;
      mouseY = e.clientY - rect.top;
    });
    hero.addEventListener('mouseleave', function () {
      mouseX = -9999;
      mouseY = -9999;
    });

    var colors = [
      { r: 180, g: 100, b: 20 },
      { r: 45, g: 90, b: 70 },
      { r: 140, g: 60, b: 15 }
    ];

    var hexagons = [];
    var isMobile = window.innerWidth < 768;
    var count = isMobile ? 12 : 25;

    function resize() {
      var rect = hero.getBoundingClientRect();
      canvas.width = rect.width;
      canvas.height = rect.height;
    }

    function rand(min, max) {
      return Math.random() * (max - min) + min;
    }

    function init() {
      isMobile = window.innerWidth < 768;
      count = isMobile ? 12 : 25;
      resize();
      hexagons = [];
      for (var i = 0; i < count; i++) {
        var c = colors[Math.floor(Math.random() * colors.length)];
        hexagons.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          size: rand(15, 40),
          vx: (Math.random() < 0.5 ? 1 : -1) * rand(0.1, 0.3),
          vy: (Math.random() < 0.5 ? 1 : -1) * rand(0.1, 0.3),
          rotation: Math.random() * Math.PI * 2,
          rotSpeed: (Math.random() < 0.5 ? 1 : -1) * rand(0.002, 0.008),
          color: c
        });
      }
    }

    function drawHex(cx, cy, size, angle) {
      ctx.beginPath();
      for (var i = 0; i < 6; i++) {
        var a = angle + (Math.PI / 3) * i;
        var px = cx + size * Math.cos(a);
        var py = cy + size * Math.sin(a);
        if (i === 0) ctx.moveTo(px, py);
        else ctx.lineTo(px, py);
      }
      ctx.closePath();
    }

    function animate() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      var w = canvas.width, h = canvas.height;

      for (var i = 0; i < hexagons.length; i++) {
        var hex = hexagons[i];

        // Mouse repulsion
        var dx = hex.x - mouseX;
        var dy = hex.y - mouseY;
        var dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 150 && dist > 0) {
          var force = (150 - dist) / 150 * 0.5;
          hex.x += (dx / dist) * force;
          hex.y += (dy / dist) * force;
        }

        hex.x += hex.vx;
        hex.y += hex.vy;
        hex.rotation += hex.rotSpeed;

        // Wrap edges
        if (hex.x < -hex.size) hex.x = w + hex.size;
        if (hex.x > w + hex.size) hex.x = -hex.size;
        if (hex.y < -hex.size) hex.y = h + hex.size;
        if (hex.y > h + hex.size) hex.y = -hex.size;
      }

      // Draw connecting lines
      for (var i = 0; i < hexagons.length; i++) {
        for (var j = i + 1; j < hexagons.length; j++) {
          var a = hexagons[i], b = hexagons[j];
          var ddx = a.x - b.x, ddy = a.y - b.y;
          var d = Math.sqrt(ddx * ddx + ddy * ddy);
          if (d < 100) {
            ctx.beginPath();
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(b.x, b.y);
            ctx.strokeStyle = 'rgba(140, 100, 50, 0.12)';
            ctx.lineWidth = 0.8;
            ctx.stroke();
          }
        }
      }

      // Draw hexagons
      for (var i = 0; i < hexagons.length; i++) {
        var hex = hexagons[i];
        var c = hex.color;
        drawHex(hex.x, hex.y, hex.size, hex.rotation);
        ctx.fillStyle = 'rgba(' + c.r + ',' + c.g + ',' + c.b + ',0.06)';
        ctx.fill();
        ctx.strokeStyle = 'rgba(' + c.r + ',' + c.g + ',' + c.b + ',0.35)';
        ctx.lineWidth = 1.5;
        ctx.stroke();
      }

      requestAnimationFrame(animate);
    }

    init();
    window.addEventListener('resize', function () { init(); });
    animate();
  })();
</script>
