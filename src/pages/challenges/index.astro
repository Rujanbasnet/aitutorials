---
import BaseLayout from '@layouts/BaseLayout.astro';
import ChallengeCard from '@components/content/ChallengeCard.astro';
import HeroImage from '@components/content/HeroImage.astro';
import { getPublishedChallenges } from '@utils/collections';

const challenges = await getPublishedChallenges();

// Define the recommended first 3 (progression order)
const progressionIds = ['tic-tac-toe', 'ai-image', 'ai-resume'];
const progressionChallenges = progressionIds
  .map(id => challenges.find(c => c.id === id))
  .filter(Boolean);
const featuredChallenge = progressionChallenges[0];

// Remaining challenges (not in the progression)
const remainingChallenges = challenges.filter(c => !progressionIds.includes(c.id));

const progressionLabels = [
  { label: 'Start here', color: 'var(--color-sage)', colorSoft: 'var(--color-sage-soft)', subtitle: 'Build something in 2 minutes' },
  { label: 'Then try', color: 'var(--color-accent)', colorSoft: 'var(--color-accent-soft)', subtitle: 'Create something visual' },
  { label: 'Level up', color: 'var(--color-clay)', colorSoft: 'var(--color-clay-soft)', subtitle: 'Make something useful' },
];
---

<BaseLayout title="Try It Yourself" description="Copy a prompt, paste it into any AI chatbot, and watch magic happen. No coding required.">

  <!-- Cinematic hero -->
  <section class="challenges-hero relative overflow-hidden" style="background: var(--color-bg-dark);">
    <img
      src="/images/challenges/magic-hero.webp"
      alt="Woman wielding a fire staff"
      class="absolute inset-0 w-full h-full object-cover opacity-60"
      width="1126"
      height="648"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-[rgba(0,0,0,0.55)] via-[rgba(0,0,0,0.25)] to-transparent"></div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
      <a href="/start/" class="text-sm text-[rgba(255,255,255,0.5)] hover:text-white transition-colors mb-6 inline-flex items-center gap-1 hero-label">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        Start Here
      </a>
      <p class="label mb-3" style="color: var(--color-accent-soft);">Try It Yourself</p>
      <h1 class="text-title mb-3 hero-title" style="color: white;">Feel the magic.</h1>
      <p class="text-lg max-w-xl hero-subtitle" style="color: rgba(255,255,255,0.8);">
        Each challenge is a single prompt you copy and paste into an AI chatbot. No coding, no setup, no catch. Just paste and watch it build something incredible.
      </p>

      <div class="flex flex-wrap items-center gap-4 mt-8">
        <div class="flex items-center gap-2 text-sm" style="color: rgba(255,255,255,0.6);">
          <div class="w-2 h-2 rounded-full pulse-dot" style="background: var(--color-sage-soft);"></div>
          Works on ChatGPT, Claude & Gemini
        </div>
        <div class="flex items-center gap-2 text-sm" style="color: rgba(255,255,255,0.6);">
          <div class="w-2 h-2 rounded-full pulse-dot" style="background: var(--color-accent-soft); animation-delay: 0.5s;"></div>
          No coding required
        </div>
        <div class="flex items-center gap-2 text-sm" style="color: rgba(255,255,255,0.6);">
          <div class="w-2 h-2 rounded-full pulse-dot" style="background: var(--color-clay-soft); animation-delay: 1s;"></div>
          2-5 minutes each
        </div>
      </div>
    </div>
  </section>

  <!-- How it works — connected steps -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12 steps-grid">
      <div class="step-card text-center p-6 relative">
        <div class="step-number w-12 h-12 rounded-xl mx-auto mb-4 flex items-center justify-center text-lg font-semibold" style="background: var(--color-accent-soft); color: var(--color-accent); font-family: var(--font-display);">
          1
        </div>
        <h3 class="text-sm font-semibold text-[var(--color-text-primary)] mb-1">Copy the prompt</h3>
        <p class="text-sm text-[var(--color-text-muted)]">Each challenge has a ready-to-use prompt. Just copy it.</p>
        <div class="step-connector hidden md:block"></div>
      </div>
      <div class="step-card text-center p-6 relative">
        <div class="step-number w-12 h-12 rounded-xl mx-auto mb-4 flex items-center justify-center text-lg font-semibold" style="background: var(--color-sage-soft); color: var(--color-sage); font-family: var(--font-display);">
          2
        </div>
        <h3 class="text-sm font-semibold text-[var(--color-text-primary)] mb-1">Paste into any AI</h3>
        <p class="text-sm text-[var(--color-text-muted)]">ChatGPT, Claude, Gemini — pick your favourite. They all work.</p>
        <div class="step-connector hidden md:block"></div>
      </div>
      <div class="step-card text-center p-6">
        <div class="step-number w-12 h-12 rounded-xl mx-auto mb-4 flex items-center justify-center text-lg font-semibold" style="background: var(--color-clay-soft); color: var(--color-clay); font-family: var(--font-display);">
          3
        </div>
        <h3 class="text-sm font-semibold text-[var(--color-text-primary)] mb-1">Watch the magic</h3>
        <p class="text-sm text-[var(--color-text-muted)]">The AI builds it for you. Play it, use it, share it.</p>
      </div>
    </div>
  </section>

  <!-- Your first 3 challenges — guided progression -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-12 lg:pb-16">
    <h2 class="text-heading mb-2 flex items-center gap-3">
      <span class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">Your first 3 challenges</span>
      <span class="flex-1 h-px bg-[var(--color-border)]"></span>
    </h2>
    <p class="text-sm text-[var(--color-text-secondary)] mb-8">
      Do these in order and you'll go from "this is cool" to "I can actually use this."
    </p>

    <ol class="relative space-y-0" id="progression-list">
      {/* Vertical timeline line */}
      <div class="timeline-line absolute left-[1.65rem] top-6 bottom-6 w-0.5" aria-hidden="true"></div>

      {progressionChallenges.map((challenge, i) => (
        <li class="relative step-item">
          <a href={`/challenges/${challenge.id}/`} class="group block pl-16 pb-8 last:pb-0">
            {/* Step number on timeline */}
            <div class="absolute left-0 top-0">
              <div class="w-[3.3rem] h-[3.3rem] rounded-full border-2 flex items-center justify-center text-base font-semibold z-10 relative transition-all" style={`border-color: ${progressionLabels[i].color}; background: ${progressionLabels[i].colorSoft}; color: ${progressionLabels[i].color}; font-family: var(--font-display);`}>
                {i + 1}
              </div>
            </div>

            {/* Card */}
            <div class="step-card rounded-xl overflow-hidden border border-[var(--color-border)] bg-[var(--color-bg-card)] hover:border-[var(--color-border-strong)] hover:shadow-md transition-all duration-300">
              {/* Thumbnail */}
              <div class="relative">
                <HeroImage
                  title={challenge.data.title}
                  category={challenge.data.category}
                  collection="challenges"
                  class="!aspect-[4/1]"
                />
                <div class="absolute top-3 left-3 flex items-center gap-2">
                  <span class="text-[0.6rem] font-bold uppercase tracking-wider px-2 py-0.5 rounded backdrop-blur-sm text-white" style={`background: ${progressionLabels[i].color}90;`}>
                    {progressionLabels[i].label}
                  </span>
                  <span class="text-[0.65rem] font-medium px-2 py-0.5 rounded backdrop-blur-sm bg-[rgba(0,0,0,0.3)] text-white">
                    {challenge.data.estimatedTime}
                  </span>
                </div>
              </div>

              {/* Content */}
              <div class="p-5 sm:p-6">
                <p class="text-xs font-medium mb-2" style={`color: ${progressionLabels[i].color};`}>
                  {progressionLabels[i].subtitle}
                </p>
                <h3 class="text-lg text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)] transition-colors mb-2" style="font-family: var(--font-display);">
                  {challenge.data.title}
                </h3>
                <p class="text-sm text-[var(--color-text-secondary)] line-clamp-2 leading-relaxed mb-3">
                  {challenge.data.description}
                </p>

                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-1.5">
                    {challenge.data.platforms.slice(0, 3).map((p: string) => (
                      <span class="text-[0.6875rem] font-medium px-2 py-0.5 rounded-full bg-[var(--color-bg-warm)] text-[var(--color-text-muted)]">
                        {p}
                      </span>
                    ))}
                  </div>
                  <span class="step-cta text-sm font-medium text-[var(--color-accent)] inline-flex items-center gap-1">
                    {i === 0 ? 'Start here' : 'Try it'}
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                    </svg>
                  </span>
                </div>
              </div>
            </div>
          </a>
        </li>
      ))}
    </ol>
  </section>

  <!-- More challenges -->
  {remainingChallenges.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
      <h2 class="text-heading mb-2 flex items-center gap-3">
        <span class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">More challenges</span>
        <span class="flex-1 h-px bg-[var(--color-border)]"></span>
      </h2>
      <p class="text-sm text-[var(--color-text-secondary)] mb-8">
        Done with the first three? Keep going.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger">
        {remainingChallenges.map((challenge) => (
          <div class="fade-in">
            <ChallengeCard
              title={challenge.data.title}
              description={challenge.data.description}
              href={`/challenges/${challenge.id}/`}
              estimatedTime={challenge.data.estimatedTime}
              difficulty={challenge.data.difficulty}
              category={challenge.data.category}
              whatYoullBuild={challenge.data.whatYoullBuild}
              platforms={challenge.data.platforms}
            />
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 text-center">
    <div class="cta-card card-warm p-8 sm:p-10 rounded-xl relative overflow-hidden">
      <div class="cta-glow"></div>
      <h3 class="text-heading mb-3 relative">Want to go deeper?</h3>
      <p class="text-[var(--color-text-secondary)] mb-6 max-w-md mx-auto relative">These challenges show you what AI can do. Our tutorials teach you how to master it.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 relative">
        <a href="/paths/ai-foundations/" class="inline-flex items-center px-6 py-3 rounded-full bg-[var(--color-text-primary)] text-white font-medium hover:bg-[var(--color-text-secondary)] transition-colors text-sm">
          Start the learning path
        </a>
        <a href="/tutorials/" class="inline-flex items-center px-6 py-3 rounded-full border border-[var(--color-border)] text-[var(--color-text-secondary)] font-medium hover:border-[var(--color-border-strong)] transition-colors text-sm">
          Browse tutorials
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Pulsing status dots ───────────────────────── */
  .pulse-dot {
    animation: pulse-ring 3s ease-in-out infinite;
  }
  @keyframes pulse-ring {
    0%, 100% { box-shadow: 0 0 0 0 currentColor; opacity: 1; }
    50%      { box-shadow: 0 0 0 4px transparent; opacity: 0.7; }
  }

  /* ── Hero text entrance ────────────────────────── */
  .hero-label {
    animation: slide-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .hero-title {
    animation: slide-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.15s both;
  }
  .hero-subtitle {
    animation: slide-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.25s both;
  }
  @keyframes slide-up {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Step connectors (dashed line between steps) ── */
  .step-connector {
    position: absolute;
    top: 2rem;
    right: -1.5rem;
    width: 3rem;
    height: 2px;
    background: repeating-linear-gradient(
      90deg,
      var(--color-border-strong) 0,
      var(--color-border-strong) 6px,
      transparent 6px,
      transparent 12px
    );
  }

  /* Step card hover */
  .step-card {
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .step-card:hover {
    transform: translateY(-2px);
  }
  .step-cta {
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .step-card:hover .step-cta {
    transform: translateX(4px);
  }

  /* How-it-works step cards */
  .steps-grid .step-card {
    border-radius: 1rem;
    transition: background 0.3s, transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .steps-grid .step-card:hover {
    background: var(--color-bg-warm);
    transform: translateY(-2px);
  }
  .step-number {
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .steps-grid .step-card:hover .step-number {
    transform: scale(1.1);
  }

  /* ── Timeline ───────────────────────────────── */
  .timeline-line {
    background: repeating-linear-gradient(
      to bottom,
      var(--color-border) 0,
      var(--color-border) 8px,
      transparent 8px,
      transparent 16px
    );
  }

  /* ── CTA glow ──────────────────────────────────── */
  .cta-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, var(--color-accent-soft) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.5s;
  }
  .cta-card:hover .cta-glow {
    opacity: 0.5;
  }

  /* Reduce motion for accessibility */
  @media (prefers-reduced-motion: reduce) {
    .hero-orb,
    .pulse-dot,
    .hero-label,
    .hero-title,
    .hero-subtitle { animation: none; }
    .step-card,
    .step-number,
    .step-cta { transition: none; }
  }
</style>
