---
import ContentLayout from '@layouts/ContentLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const challenges = await getCollection('challenges');
  return challenges.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Compute prev/next and related articles
// Challenges sort by difficulty then title (matching collections.ts)
const difficultyOrder: Record<string, number> = { beginner: 0, intermediate: 1, advanced: 2 };
const allEntries = (await getCollection('challenges', ({ data }) => !data.draft))
  .sort((a, b) => {
    const da = difficultyOrder[a.data.difficulty] ?? 1;
    const db = difficultyOrder[b.data.difficulty] ?? 1;
    if (da !== db) return da - db;
    return a.data.title.localeCompare(b.data.title);
  });

const currentIndex = allEntries.findIndex((e) => e.id === entry.id);
const prevEntry = currentIndex > 0 ? allEntries[currentIndex - 1] : null;
const nextEntry = currentIndex < allEntries.length - 1 ? allEntries[currentIndex + 1] : null;

const prevArticle = prevEntry ? { title: prevEntry.data.title, href: `/challenges/${prevEntry.id}/` } : null;
const nextArticle = nextEntry ? { title: nextEntry.data.title, href: `/challenges/${nextEntry.id}/` } : null;

const others = allEntries.filter((e) => e.id !== entry.id);
const sameCategory = others.filter((e) => e.data.category === entry.data.category);
const different = others.filter((e) => e.data.category !== entry.data.category);
const relatedRaw = [...sameCategory, ...different].slice(0, 3);

const relatedArticles = relatedRaw.map((e) => ({
  title: e.data.title,
  description: e.data.description,
  href: `/challenges/${e.id}/`,
  pubDate: e.data.pubDate,
  tags: e.data.tags,
  difficulty: e.data.difficulty,
  image: e.data.image,
  body: e.body || '',
  category: e.data.category,
  collection: 'challenges',
}));
---

<ContentLayout
  title={entry.data.title}
  description={entry.data.description}
  pubDate={entry.data.pubDate}
  author={entry.data.author}
  image={entry.data.image}
  tags={entry.data.tags}
  difficulty={entry.data.difficulty}
  estimatedTime={entry.data.estimatedTime}
  body={entry.body || ''}
  collection="challenges"
  category={entry.data.category}
  prevArticle={prevArticle}
  nextArticle={nextArticle}
  relatedArticles={relatedArticles}
>
  <Content />
</ContentLayout>
