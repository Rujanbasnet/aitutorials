---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Newsletter" description="Subscribe to the AI Tutorials newsletter for weekly AI tutorials, tool reviews, and industry insights.">
  <section class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
    <div class="text-center mb-12">
      <p class="label mb-4">Newsletter</p>
      <h1 class="text-display mb-5">
        Stay ahead of <span class="text-[var(--color-accent)]">AI</span>
      </h1>
      <p class="text-lg text-[var(--color-text-secondary)] leading-relaxed">
        Weekly curated AI tutorials, tool reviews, and insights delivered straight to your inbox.
      </p>
    </div>

    <!-- Newsletter Form -->
    <div class="card p-8 sm:p-10 mb-12">
      <form
        id="newsletter-form"
        method="POST"
        action="https://b4556b17.sibforms.com/serve/MUIFAHjyU7YMpzSHJctCG76TeifU-zeadE5xjY7m1BVB8OAp92-d_PQhCoOWQEOmk4MS7WNag_cREDOfr2gD_9admQ-lmt1YRRSin829IqgP-7m6OgZ0UjrDdasmFSz8flCQlk8y_YBI-lKiQQ9qqxWgkhUmBJsqzUenQVwYH8PQvtI1fDVLICJxRSqP5KofXY00WORK9nXSGAsqiQ=="
        class="space-y-5"
      >
        <div>
          <label for="EMAIL" class="block text-sm font-medium text-[var(--color-text-secondary)] mb-2">
            Email address
          </label>
          <input
            type="email"
            id="EMAIL"
            name="EMAIL"
            required
            placeholder="you@example.com"
            class="w-full px-4 py-3 rounded-lg bg-[var(--color-bg-warm)] border border-[var(--color-border)] text-[var(--color-text-primary)] placeholder:text-[var(--color-text-muted)] focus:outline-none focus:border-[var(--color-accent)] focus:ring-1 focus:ring-[var(--color-accent)] transition-all"
          />
        </div>
        <!-- Honeypot anti-spam field -->
        <div style="position: absolute; left: -5000px;" aria-hidden="true">
          <input type="text" name="email_address_check" value="" tabindex="-1" autocomplete="off" />
        </div>
        <input type="hidden" name="locale" value="en" />
        <button
          type="submit"
          class="w-full px-6 py-3 rounded-full bg-[var(--color-text-primary)] text-white font-medium hover:bg-[var(--color-text-secondary)] transition-colors"
        >
          Subscribe
        </button>
        <p class="text-xs text-[var(--color-text-muted)] text-center">
          No spam. Unsubscribe anytime.
        </p>
      </form>
      <!-- Success message (hidden by default) -->
      <div id="newsletter-success" class="hidden text-center py-6">
        <p class="text-heading mb-3" style="font-family: var(--font-display)">You're in!</p>
        <p class="text-sm text-[var(--color-text-secondary)]">
          Check your inbox to confirm your subscription.
        </p>
      </div>
    </div>

    <!-- What you'll get -->
    <div class="fade-in">
      <p class="label text-center mb-6">What you'll get</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="card-warm p-5 rounded-xl">
          <div class="text-sm font-semibold text-[var(--color-accent)] mb-1">Tutorials</div>
          <p class="text-sm text-[var(--color-text-secondary)]">Step-by-step guides on the latest AI tools and techniques.</p>
        </div>
        <div class="card-warm p-5 rounded-xl">
          <div class="text-sm font-semibold text-[var(--color-sage)] mb-1">Tool Reviews</div>
          <p class="text-sm text-[var(--color-text-secondary)]">Honest reviews of AI products and platforms.</p>
        </div>
        <div class="card-warm p-5 rounded-xl">
          <div class="text-sm font-semibold text-[var(--color-clay)] mb-1">Industry News</div>
          <p class="text-sm text-[var(--color-text-secondary)]">Curated AI news that matters, no noise.</p>
        </div>
        <div class="card-warm p-5 rounded-xl">
          <div class="text-sm font-semibold text-[var(--color-text-primary)] mb-1">Free Resources</div>
          <p class="text-sm text-[var(--color-text-secondary)]">Prompt libraries, cheat sheets, and templates.</p>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    const form = document.getElementById('newsletter-form');
    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(form);
        const btn = form.querySelector('button[type="submit"]');
        const originalText = btn.textContent;
        btn.textContent = 'Subscribing...';
        btn.disabled = true;

        try {
          await fetch(form.action, {
            method: 'POST',
            body: formData,
            mode: 'no-cors',
          });
          form.classList.add('hidden');
          document.getElementById('newsletter-success').classList.remove('hidden');
        } catch (err) {
          btn.textContent = originalText;
          btn.disabled = false;
          alert('Something went wrong. Please try again.');
        }
      });
    }
  </script>
</BaseLayout>
