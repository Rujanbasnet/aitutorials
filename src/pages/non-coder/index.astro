---
import BaseLayout from '@layouts/BaseLayout.astro';
import PageHero from '@components/global/PageHero.astro';
import PostCard from '@components/content/PostCard.astro';
import FeaturedPost from '@components/content/FeaturedPost.astro';
import { getPublishedNonCoder } from '@utils/collections';

const posts = await getPublishedNonCoder();
const featured = posts[0];
const rest = posts.slice(1);
---

<BaseLayout title="Non-Coder" description="AI explained for everyone. Plain-language guides for people who use AI tools but don't write code.">

  <PageHero
    tag="For Everyone"
    title="Non-Coder"
    description="AI explained for everyone. No jargon, no prerequisites, just clear answers to the stuff that actually matters."
    gradient="sage"
    image="/images/non-coder/scholar.webp"
    imageAlt="A scholar writing with a quill pen"
    stats={[
      { label: `${posts.length} guides`, color: 'var(--color-sage)' },
      { label: 'Zero code required', color: 'var(--color-accent)' },
      { label: 'Plain language', color: 'var(--color-clay)' },
    ]}
  />

  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    {posts.length > 0 ? (
      <>
        <!-- Featured latest guide -->
        {featured && (
          <div class="mb-8 fade-in">
            <FeaturedPost
              title={featured.data.title}
              description={featured.data.description}
              href={`/non-coder/${featured.id}/`}
              pubDate={featured.data.pubDate}
              tags={featured.data.tags}
              image={featured.data.image}
              body={featured.body || ''}
              category={featured.data.category}
              collection="non-coder"
            />
          </div>
        )}

        {rest.length > 0 && (
          <>
            <div class="flex items-center gap-3 mb-8">
              <h2 class="text-heading">More guides</h2>
              <div class="flex-1 h-px bg-[var(--color-border)]"></div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger">
              {rest.map((post) => (
                <div class="fade-in">
                  <PostCard
                    title={post.data.title}
                    description={post.data.description}
                    href={`/non-coder/${post.id}/`}
                    pubDate={post.data.pubDate}
                    tags={post.data.tags}
                    image={post.data.image}
                    body={post.body || ''}
                    category={post.data.category}
                    collection="non-coder"
                  />
                </div>
              ))}
            </div>
          </>
        )}
      </>
    ) : (
      <div class="card-warm p-16 text-center rounded-xl">
        <h3 class="text-heading mb-2">Coming soon</h3>
        <p class="text-[var(--color-text-secondary)]">Non-coder guides are being written. Check back soon.</p>
      </div>
    )}
  </section>

  <!-- CTA -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 text-center">
    <div class="cta-card card-warm p-8 sm:p-10 rounded-xl relative overflow-hidden">
      <div class="cta-glow"></div>
      <h3 class="text-heading mb-3 relative">Ready to see AI in action?</h3>
      <p class="text-[var(--color-text-secondary)] mb-6 max-w-md mx-auto relative">Try one of our challenges -- copy a prompt, paste it into ChatGPT or Claude, and build something incredible in 2 minutes flat.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 relative">
        <a href="/challenges/" class="inline-flex items-center px-6 py-3 rounded-full bg-[var(--color-text-primary)] text-white font-medium hover:bg-[var(--color-text-secondary)] transition-colors text-sm">
          Try a challenge
        </a>
        <a href="/start/" class="inline-flex items-center px-6 py-3 rounded-full border border-[var(--color-border)] text-[var(--color-text-secondary)] font-medium hover:border-[var(--color-border-strong)] transition-colors text-sm">
          Start learning
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .pulse-dot {
    animation: pulse-ring 3s ease-in-out infinite;
  }
  @keyframes pulse-ring {
    0%, 100% { box-shadow: 0 0 0 0 currentColor; opacity: 1; }
    50%      { box-shadow: 0 0 0 4px transparent; opacity: 0.7; }
  }

  .hero-label {
    animation: slide-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .hero-title {
    animation: slide-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }
  .hero-subtitle {
    animation: slide-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both;
  }
  @keyframes slide-up {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .cta-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, var(--color-sage-soft) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 0.5s;
  }
  .cta-card:hover .cta-glow {
    opacity: 0.5;
  }

  @media (prefers-reduced-motion: reduce) {
    .pulse-dot,
    .hero-label,
    .hero-title,
    .hero-subtitle { animation: none; }
  }
</style>
