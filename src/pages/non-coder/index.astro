---
import BaseLayout from '@layouts/BaseLayout.astro';
import PostCard from '@components/content/PostCard.astro';
import { getPublishedNonCoder } from '@utils/collections';

const posts = await getPublishedNonCoder();
---

<BaseLayout title="Non-Coder" description="AI explained for everyone. Plain-language guides for people who use AI tools but don't write code.">
  <section class="relative overflow-hidden bg-warm">
    <img
      src="https://images.unsplash.com/photo-1516321318423-f06f85e504b3?w=1600&h=400&fit=crop&q=80"
      alt=""
      class="absolute inset-0 w-full h-full object-cover opacity-[0.06]"
      loading="eager"
      aria-hidden="true"
    />
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
      <p class="label mb-3">For Everyone</p>
      <h1 class="text-title mb-3">Non-Coder</h1>
      <p class="text-lg text-[var(--color-text-secondary)] max-w-xl">
        AI explained for everyone. No jargon, no prerequisites, just clear answers to the stuff that actually matters.
      </p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger">
        {posts.map((post) => (
          <div class="fade-in">
            <PostCard
              title={post.data.title}
              description={post.data.description}
              href={`/non-coder/${post.id}/`}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              image={post.data.image}
              body={post.body || ''}
            />
          </div>
        ))}
      </div>
    ) : (
      <div class="card-warm p-16 text-center rounded-xl">
        <h3 class="text-heading mb-2">Coming soon</h3>
        <p class="text-[var(--color-text-secondary)]">Non-coder guides are being written. Check back soon.</p>
      </div>
    )}
  </section>
</BaseLayout>
