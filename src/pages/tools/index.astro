---
import BaseLayout from '@layouts/BaseLayout.astro';
import tools from '@data/tools.json';

const categories = [...new Set(tools.map(t => t.category))].sort();
const trendingCount = tools.filter(t => t.trending).length;
const newCount = tools.filter(t => t.new).length;
---

<BaseLayout
  title="AI Tools & Apps Directory"
  description="Discover the best AI tools, apps, and websites for every use case. Curated directory with pricing, categories, and honest descriptions."
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-warm">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, var(--color-text-primary) 1px, transparent 0); background-size: 24px 24px;"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
      <p class="label mb-3">Directory</p>
      <h1 class="text-title mb-3">AI Tools & Apps</h1>
      <p class="text-lg text-[var(--color-text-secondary)] max-w-xl mb-6">
        Curated collection of the best AI tools, apps, and platforms. Updated regularly with new and trending picks.
      </p>
      <div class="flex gap-4 text-sm text-[var(--color-text-muted)]">
        <span><strong class="text-[var(--color-text-primary)]">{tools.length}</strong> tools</span>
        <span><strong class="text-[var(--color-accent)]">{trendingCount}</strong> trending</span>
        <span><strong class="text-[var(--color-sage)]">{newCount}</strong> new</span>
      </div>
    </div>
  </section>

  <!-- Affiliate Disclosure -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-8">
    <p class="text-xs text-[var(--color-text-muted)] italic">
      Some links on this page may be affiliate links. We only recommend tools we genuinely find useful.
    </p>
  </div>

  <!-- Filter Bar -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-6 pb-2">
    <div class="flex flex-wrap gap-2" id="filter-bar">
      <button
        class="filter-btn filter-active px-3 py-1.5 text-sm font-medium rounded-full border border-[var(--color-border)] transition-all"
        data-category="all"
      >
        All
      </button>
      {categories.map((cat) => (
        <button
          class="filter-btn px-3 py-1.5 text-sm font-medium rounded-full border border-[var(--color-border)] text-[var(--color-text-secondary)] hover:border-[var(--color-text-primary)] hover:text-[var(--color-text-primary)] transition-all"
          data-category={cat}
        >
          {cat}
        </button>
      ))}
    </div>
  </section>

  <!-- Tools Grid -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 stagger" id="tools-grid">
      {tools.map((tool) => {
        const linkUrl = tool.affiliateUrl || tool.url;
        const isAffiliate = !!tool.affiliateUrl;
        return (
          <div class="fade-in tool-card" data-category={tool.category}>
            <div class="group relative bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-xl p-5 hover:border-[var(--color-border-strong)] hover:shadow-sm transition-all duration-300">
              {/* Header row */}
              <div class="flex items-start justify-between mb-3">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1">
                    <h3 class="text-base font-medium text-[var(--color-text-primary)] truncate" style="font-family: var(--font-display); font-size: 1.125rem;">
                      {tool.name}
                    </h3>
                    {tool.new && (
                      <span class="inline-flex items-center px-1.5 py-0.5 text-[0.6rem] font-bold uppercase tracking-wider rounded bg-[var(--color-sage-soft)] text-[var(--color-sage)]">
                        New
                      </span>
                    )}
                    {tool.trending && (
                      <span class="inline-flex items-center px-1.5 py-0.5 text-[0.6rem] font-bold uppercase tracking-wider rounded bg-[var(--color-accent-soft)] text-[var(--color-accent-hover)]">
                        Trending
                      </span>
                    )}
                  </div>
                  <span class="inline-flex items-center px-2 py-0.5 text-[0.625rem] font-semibold uppercase tracking-wider rounded-sm bg-[var(--color-bg-warm)] text-[var(--color-text-muted)]">
                    {tool.category}
                  </span>
                </div>
              </div>

              {/* Description */}
              <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-4 line-clamp-3">
                {tool.description}
              </p>

              {/* Footer */}
              <div class="flex items-center justify-between">
                <div class="text-sm">
                  <span class:list={[
                    'font-medium',
                    tool.pricing === 'Free' ? 'text-[var(--color-sage)]' :
                    tool.pricing === 'Freemium' ? 'text-[var(--color-accent)]' :
                    'text-[var(--color-text-secondary)]'
                  ]}>
                    {tool.pricing}
                  </span>
                  {tool.pricingDetail !== tool.pricing && (
                    <span class="text-[var(--color-text-muted)] text-xs ml-1">
                      &middot; {tool.pricingDetail}
                    </span>
                  )}
                </div>
                <a
                  href={linkUrl}
                  target="_blank"
                  rel={isAffiliate ? "noopener nofollow sponsored" : "noopener nofollow"}
                  class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium rounded-full border border-[var(--color-border)] text-[var(--color-text-secondary)] hover:bg-[var(--color-text-primary)] hover:text-white hover:border-[var(--color-text-primary)] transition-all"
                >
                  Visit
                  <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                  </svg>
                </a>
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Empty state -->
    <div id="no-results" class="hidden py-16 text-center">
      <p class="text-lg text-[var(--color-text-muted)]" style="font-family: var(--font-display);">No tools in this category yet.</p>
      <p class="text-sm text-[var(--color-text-muted)] mt-2">Check back soon — we add new tools regularly.</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <div class="bg-warm rounded-xl p-8 sm:p-12 text-center">
      <h2 class="text-heading mb-3">Know a great AI tool?</h2>
      <p class="text-[var(--color-text-secondary)] mb-6 max-w-md mx-auto">
        We're always looking for new tools to add. Send us a suggestion and we'll review it.
      </p>
      <a
        href="/newsletter/"
        class="inline-flex items-center gap-2 px-6 py-2.5 rounded-full bg-[var(--color-text-primary)] text-white text-sm font-medium hover:bg-[var(--color-text-secondary)] transition-colors"
      >
        Subscribe for updates
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script is:inline>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const toolCards = document.querySelectorAll('.tool-card');
  const noResults = document.getElementById('no-results');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      // Update active state
      filterBtns.forEach(b => {
        b.classList.remove('filter-active');
        b.classList.add('text-[var(--color-text-secondary)]');
      });
      btn.classList.add('filter-active');
      btn.classList.remove('text-[var(--color-text-secondary)]');

      const category = btn.dataset.category;
      let visibleCount = 0;

      toolCards.forEach(card => {
        if (category === 'all' || card.dataset.category === category) {
          card.style.display = '';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      });

      noResults.classList.toggle('hidden', visibleCount > 0);
    });
  });
</script>
