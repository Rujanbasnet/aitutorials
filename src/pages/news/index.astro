---
import BaseLayout from '@layouts/BaseLayout.astro';
import PostCard from '@components/content/PostCard.astro';
import { getPublishedNews } from '@utils/collections';

const news = await getPublishedNews();
---

<BaseLayout title="AI News" description="Stay up to date with the latest AI news, product launches, research breakthroughs, and industry analysis.">
  <section class="relative overflow-hidden" style="background: var(--color-bg-dark);">
    <img
      src="/images/news/newspaper.jpg"
      alt="AI news headlines on a newspaper"
      class="absolute inset-0 w-full h-full object-cover opacity-60"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-[rgba(20,20,19,0.7)] via-[rgba(20,20,19,0.3)] to-transparent"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
      <p class="label mb-3" style="color: var(--color-accent-soft);">Stay Current</p>
      <h1 class="text-title mb-3" style="color: white;">AI News</h1>
      <p class="text-lg max-w-xl" style="color: rgba(255,255,255,0.75);">
        The latest in AI — product launches, research breakthroughs, and industry analysis.
      </p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    {news.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger">
        {news.map((item) => (
          <div class="fade-in">
            <PostCard
              title={item.data.title}
              description={item.data.description}
              href={`/news/${item.id}/`}
              pubDate={item.data.pubDate}
              tags={item.data.tags}
              image={item.data.image}
              body={item.body || ''}
              category={item.data.category}
              collection="news"
            />
          </div>
        ))}
      </div>
    ) : (
      <div class="card-warm p-16 text-center rounded-xl">
        <h3 class="text-heading mb-2">Coming soon</h3>
        <p class="text-[var(--color-text-secondary)]">News articles are being written. Check back soon.</p>
      </div>
    )}
  </section>
</BaseLayout>
