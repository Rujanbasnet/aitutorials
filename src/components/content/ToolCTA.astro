---
import toolsData from '../../data/tools.json';

interface Props {
  tool: string;
  /** Override the default description */
  pitch?: string;
}

const { tool: toolName, pitch } = Astro.props;

const toolEntry = toolsData.find(
  (t: any) => t.name.toLowerCase() === toolName.toLowerCase()
);

if (!toolEntry) {
  throw new Error(`ToolCTA: tool "${toolName}" not found in tools.json`);
}

const linkUrl = toolEntry.affiliateUrl || toolEntry.url;
const isAffiliate = !!toolEntry.affiliateUrl;
const description = pitch || toolEntry.description;
---

<aside class="my-10 card-warm p-6 sm:p-8 rounded-xl not-prose">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div class="flex-1">
      <div class="flex items-center gap-2 mb-2">
        <span class="tag text-xs">{toolEntry.category}</span>
        <span class:list={[
          'text-xs font-medium px-1.5 py-0.5 rounded',
          toolEntry.pricing === 'Free' ? 'text-[var(--color-sage)] bg-[var(--color-sage)]/10' :
          toolEntry.pricing === 'Freemium' ? 'text-[var(--color-accent)] bg-[var(--color-accent)]/10' :
          'text-[var(--color-text-muted)] bg-[var(--color-text-muted)]/10'
        ]}>
          {toolEntry.pricingDetail}
        </span>
      </div>
      <h4 class="text-lg text-[var(--color-text-primary)] mb-1" style="font-family: var(--font-display)">
        {toolEntry.name}
      </h4>
      <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
        {description}
      </p>
    </div>
    <div class="flex flex-col items-end gap-2 flex-shrink-0">
      <a
        href={linkUrl}
        target="_blank"
        rel={isAffiliate ? "noopener nofollow sponsored" : "noopener nofollow"}
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-[var(--color-accent)] text-white text-sm font-medium hover:bg-[var(--color-accent-hover)] transition-colors whitespace-nowrap"
      >
        Try {toolEntry.name}
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
      {isAffiliate && (
        <span class="text-[0.65rem] text-[var(--color-text-muted)]">Affiliate link</span>
      )}
    </div>
  </div>
</aside>
