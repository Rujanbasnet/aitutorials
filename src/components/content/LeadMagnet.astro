---
interface Props {
  resourceName: string;
  description: string;
  ctaText?: string;
}

const {
  resourceName,
  description,
  ctaText = `Get the free ${resourceName}`,
} = Astro.props;

const formId = `lead-magnet-${resourceName.toLowerCase().replace(/\s+/g, '-')}`;
---

<aside class="my-10 not-prose">
  <div class="p-6 sm:p-8 rounded-xl border-2 border-dashed border-[var(--color-accent)] bg-[var(--color-accent-soft)]/30">
    <div class="flex items-start gap-3 mb-4">
      <div class="w-10 h-10 rounded-lg bg-[var(--color-accent-soft)] flex items-center justify-center flex-shrink-0">
        <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
        </svg>
      </div>
      <div>
        <h4 class="text-lg text-[var(--color-text-primary)] mb-1" style="font-family: var(--font-display)">
          Free: {resourceName}
        </h4>
        <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{description}</p>
      </div>
    </div>

    <form
      id={formId}
      method="POST"
      action="https://b4556b17.sibforms.com/serve/MUIFAHjyU7YMpzSHJctCG76TeifU-zeadE5xjY7m1BVB8OAp92-d_PQhCoOWQEOmk4MS7WNag_cREDOfr2gD_9admQ-lmt1YRRSin829IqgP-7m6OgZ0UjrDdasmFSz8flCQlk8y_YBI-lKiQQ9qqxWgkhUmBJsqzUenQVwYH8PQvtI1fDVLICJxRSqP5KofXY00WORK9nXSGAsqiQ=="
    >
      <div class="flex flex-col sm:flex-row gap-3">
        <input
          type="email"
          name="EMAIL"
          required
          placeholder="you@example.com"
          class="flex-1 px-4 py-2.5 rounded-full bg-white border border-[var(--color-border)] text-[var(--color-text-primary)] placeholder:text-[var(--color-text-muted)] focus:outline-none focus:border-[var(--color-accent)] focus:ring-1 focus:ring-[var(--color-accent)] transition-all text-sm"
        />
        <button
          type="submit"
          class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-full bg-[var(--color-accent)] text-white font-medium hover:bg-[var(--color-accent-hover)] transition-colors text-sm whitespace-nowrap"
        >
          {ctaText}
        </button>
      </div>
      <div style="position: absolute; left: -5000px;" aria-hidden="true">
        <input type="text" name="email_address_check" value="" tabindex="-1" autocomplete="off" />
      </div>
      <input type="hidden" name="locale" value="en" />
      <p class="text-xs text-[var(--color-text-muted)] mt-2">We'll email you the download link. No spam.</p>
    </form>

    <div id={`${formId}-success`} style="display:none;" class="text-center py-4">
      <p class="text-[var(--color-text-primary)] font-medium mb-1" style="font-family: var(--font-display)">Check your inbox!</p>
      <p class="text-sm text-[var(--color-text-secondary)]">We've sent the download link to your email.</p>
    </div>
  </div>
</aside>

<script is:inline define:vars={{ formId }}>
  const leadForm = document.getElementById(formId);
  if (leadForm) {
    leadForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(leadForm);
      const btn = leadForm.querySelector('button[type="submit"]');
      const originalHTML = btn.innerHTML;
      btn.textContent = 'Sending...';
      btn.disabled = true;
      try {
        await fetch(leadForm.action, { method: 'POST', body: formData, mode: 'no-cors' });
        leadForm.style.display = 'none';
        document.getElementById(`${formId}-success`).style.display = 'block';
      } catch (err) {
        btn.innerHTML = originalHTML;
        btn.disabled = false;
      }
    });
  }
</script>
