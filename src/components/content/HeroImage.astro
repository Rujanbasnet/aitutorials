---
interface Props {
  title: string;
  category?: string;
  collection?: string;
  class?: string;
}

const { title, category = '', collection = '', class: className = '' } = Astro.props;

// Deterministic hash for consistent visuals per title
function hashCode(str: string, seed: number = 0): number {
  let hash = seed;
  for (let i = 0; i < str.length; i++) {
    hash = ((hash << 5) - hash) + str.charCodeAt(i);
    hash |= 0;
  }
  return Math.abs(hash);
}

const h1 = hashCode(title, 0);
const h2 = hashCode(title, 17);

// Warm editorial palettes — only tones from the site's paper aesthetic
type Palette = { bg: string; accent: string; text: string; border: string };

const palettes: Palette[] = [
  { bg: '#F5F1EB', accent: 'var(--color-accent)',  text: 'var(--color-text-primary)', border: 'var(--color-accent)' },
  { bg: '#F0F5F1', accent: 'var(--color-sage)',    text: 'var(--color-text-primary)', border: 'var(--color-sage)' },
  { bg: '#F5F0EB', accent: 'var(--color-clay)',    text: 'var(--color-text-primary)', border: 'var(--color-clay)' },
  { bg: '#EDEDEB', accent: 'var(--color-text-secondary)', text: 'var(--color-text-primary)', border: 'var(--color-border-strong)' },
  { bg: '#FEF3C7', accent: 'var(--color-accent-hover)', text: 'var(--color-text-primary)', border: 'var(--color-accent)' },
  { bg: '#D8F3DC', accent: 'var(--color-sage)',    text: 'var(--color-text-primary)', border: 'var(--color-sage)' },
  { bg: '#FDE8D0', accent: 'var(--color-clay)',    text: 'var(--color-text-primary)', border: 'var(--color-clay)' },
];

// Collection influences palette selection
const collectionOffset: Record<string, number> = {
  tutorials: 0, news: 1, blog: 2, 'non-coder': 3,
  challenges: 4, tools: 5, resources: 6, products: 0,
};

const offset = collectionOffset[collection] ?? 0;
const palette = palettes[(offset + h1) % palettes.length];

// Decorative element variations
const decoVariants = [
  'deco-corner',
  'deco-line',
  'deco-bracket',
  'deco-dots',
  'deco-rule',
];
const decoClass = decoVariants[h2 % decoVariants.length];

// Category label
const label = category || collection;
---

<div
  class:list={['hero-img', decoClass, className]}
  style={`--hi-bg: ${palette.bg}; --hi-accent: ${palette.accent}; --hi-text: ${palette.text}; --hi-border: ${palette.border};`}
  role="img"
  aria-label={title}
>
  <!-- Paper texture -->
  <div class="hero-img__texture" aria-hidden="true"></div>

  <!-- Title as headline -->
  <div class="hero-img__content">
    {label && (
      <span class="hero-img__label">{label}</span>
    )}
    <h4 class="hero-img__title">{title}</h4>
  </div>
</div>

<style>
  .hero-img {
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--hi-bg);
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }

  .hero-img__texture {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.7' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    opacity: 0.04;
    pointer-events: none;
  }

  /* Content block — title + category */
  .hero-img__content {
    position: relative;
    z-index: 1;
    padding: 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: 100%;
  }

  .hero-img__label {
    font-family: var(--font-body);
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--hi-accent);
    opacity: 0.8;
  }

  .hero-img__title {
    font-family: var(--font-display);
    font-size: clamp(1.125rem, 1rem + 0.5vw, 1.5rem);
    font-style: italic;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--hi-text);
    opacity: 0.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Decorative variants ─────────────────── */

  /* Corner bracket marks */
  .deco-corner::before,
  .deco-corner::after {
    content: '';
    position: absolute;
    width: 24px;
    height: 24px;
    border-color: var(--hi-border);
    border-style: solid;
    opacity: 0.2;
  }
  .deco-corner::before {
    top: 16px; left: 16px;
    border-width: 2px 0 0 2px;
  }
  .deco-corner::after {
    bottom: 16px; right: 16px;
    border-width: 0 2px 2px 0;
  }

  /* Horizontal accent line */
  .deco-line::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 20px;
    right: 20px;
    height: 1px;
    background: var(--hi-border);
    opacity: 0.15;
  }

  /* Typographic brackets */
  .deco-bracket::before,
  .deco-bracket::after {
    font-family: var(--font-display);
    font-size: 3rem;
    color: var(--hi-accent);
    opacity: 0.1;
    position: absolute;
    line-height: 1;
  }
  .deco-bracket::before {
    content: '[';
    top: 12px; left: 16px;
  }
  .deco-bracket::after {
    content: ']';
    bottom: 12px; right: 16px;
  }

  /* Dot grid */
  .deco-dots::before {
    content: '';
    position: absolute;
    inset: 20px;
    background-image: radial-gradient(circle, var(--hi-border) 1px, transparent 1px);
    background-size: 16px 16px;
    opacity: 0.12;
  }

  /* Editorial rule */
  .deco-rule::before {
    content: '';
    position: absolute;
    bottom: 40px;
    left: 20px;
    width: 48px;
    height: 2px;
    background: var(--hi-accent);
    opacity: 0.3;
    border-radius: 1px;
  }
</style>
