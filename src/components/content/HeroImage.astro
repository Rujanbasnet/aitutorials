---
interface Props {
  title: string;
  category?: string;
  collection?: string;
  class?: string;
}

const { title, category = '', collection = '', class: className = '' } = Astro.props;

// Multiple deterministic hashes from title — each visual property gets its own seed
function hashCode(str: string, seed: number = 0): number {
  let hash = seed;
  for (let i = 0; i < str.length; i++) {
    hash = ((hash << 5) - hash) + str.charCodeAt(i);
    hash |= 0;
  }
  return Math.abs(hash);
}

const h1 = hashCode(title, 0);    // palette
const h2 = hashCode(title, 17);   // gradient variant
const h3 = hashCode(title, 31);   // pattern type
const h4 = hashCode(title, 53);   // shape
const h5 = hashCode(title, 97);   // angle
const angle = (h5 % 12) * 30;

// ── Color palettes ────────────────────────────────────────────
// Each palette: [from, to, patternColor, textColor]
type Palette = [string, string, string, string];

const palettes: Palette[] = [
  ['#2D6A4F', '#40916C', 'rgba(255,255,255,0.12)', 'white'],        // forest
  ['#264653', '#2A9D8F', 'rgba(255,255,255,0.12)', 'white'],        // teal depths
  ['#7F5539', '#DDB892', 'rgba(255,255,255,0.10)', 'white'],        // amber earth
  ['#5A189A', '#9D4EDD', 'rgba(255,255,255,0.10)', 'white'],        // violet
  ['#1B4332', '#95D5B2', 'rgba(255,255,255,0.08)', 'white'],        // emerald mist
  ['#6D597A', '#B56576', 'rgba(255,255,255,0.10)', 'white'],        // mauve rose
  ['#003049', '#669BBC', 'rgba(255,255,255,0.10)', 'white'],        // deep navy
  ['#774936', '#C38E70', 'rgba(255,255,255,0.10)', 'white'],        // terracotta
  ['#2B2D42', '#8D99AE', 'rgba(255,255,255,0.10)', 'white'],        // gunmetal
  ['#606C38', '#FEFAE0', 'rgba(0,0,0,0.06)', 'var(--color-text-primary)'],  // olive dawn
  ['#3A0CA3', '#4CC9F0', 'rgba(255,255,255,0.10)', 'white'],        // electric blue
  ['#9B2226', '#CA6702', 'rgba(255,255,255,0.08)', 'white'],        // crimson sunset
];

// Collection influences which subset of palettes to prefer
const collectionOffset: Record<string, number> = {
  tutorials: 0,
  news: 3,
  blog: 5,
  'non-coder': 8,
  nonCoder: 8,
  challenges: 0,  // challenges use full range
  tools: 2,
  resources: 6,
  products: 4,
};

const offset = collectionOffset[collection] ?? 0;
const paletteIdx = (offset + h1) % palettes.length;

const [colorFrom, colorTo, patternColor, textColor] = palettes[paletteIdx];

// ── Gradient styles ───────────────────────────────────────────
const gradientVariants = [
  `linear-gradient(${angle}deg, ${colorFrom} 0%, ${colorTo} 100%)`,
  `linear-gradient(${angle}deg, ${colorFrom} 0%, ${colorTo} 60%, ${colorFrom} 100%)`,
  `radial-gradient(ellipse at ${20 + (h2 % 60)}% ${20 + (h2 % 60)}%, ${colorTo} 0%, ${colorFrom} 100%)`,
  `linear-gradient(${angle}deg, ${colorFrom} 0%, ${colorTo} 50%, ${colorFrom}CC 100%)`,
];
const gradient = gradientVariants[h2 % gradientVariants.length];

// ── SVG patterns ──────────────────────────────────────────────
const patternTypes = ['dots', 'diagonal', 'circles', 'hexagon', 'waves'] as const;
const patternType = patternTypes[h3 % patternTypes.length];

const patternId = `p-${h1}-${h3}`;
const patterns: Record<string, string> = {
  dots: `<pattern id="${patternId}" width="20" height="20" patternUnits="userSpaceOnUse"><circle cx="10" cy="10" r="2" fill="${patternColor}"/></pattern>`,
  diagonal: `<pattern id="${patternId}" width="14" height="14" patternUnits="userSpaceOnUse" patternTransform="rotate(${45 + (h3 % 2) * 45})"><line x1="0" y1="0" x2="0" y2="14" stroke="${patternColor}" stroke-width="1.5"/></pattern>`,
  circles: `<pattern id="${patternId}" width="36" height="36" patternUnits="userSpaceOnUse"><circle cx="18" cy="18" r="10" fill="none" stroke="${patternColor}" stroke-width="1.2"/></pattern>`,
  hexagon: `<pattern id="${patternId}" width="28" height="48" patternUnits="userSpaceOnUse"><path d="M14 0L28 8v16L14 32 0 24V8z" fill="none" stroke="${patternColor}" stroke-width="0.8"/><path d="M14 32L28 40v8M14 32L0 40v8" fill="none" stroke="${patternColor}" stroke-width="0.8"/></pattern>`,
  waves: `<pattern id="${patternId}" width="40" height="20" patternUnits="userSpaceOnUse"><path d="M0 10 Q10 0 20 10 Q30 20 40 10" fill="none" stroke="${patternColor}" stroke-width="1.2"/></pattern>`,
};

const patternSvg = patterns[patternType];

// ── Decorative SVG shape (unique per card) ────────────────────
const shapeVariants = [
  // Large circle, top-right
  `<circle cx="85%" cy="20%" r="80" fill="${patternColor}" opacity="0.5"/>`,
  // Diamond, center-right
  `<rect x="70%" y="15%" width="60" height="60" rx="4" transform="rotate(45, 80%, 35%)" fill="${patternColor}" opacity="0.4"/>`,
  // Two overlapping circles
  `<circle cx="78%" cy="30%" r="50" fill="${patternColor}" opacity="0.3"/><circle cx="88%" cy="25%" r="35" fill="${patternColor}" opacity="0.4"/>`,
  // Triangle
  `<polygon points="75%,10% 95%,50% 55%,50%" fill="${patternColor}" opacity="0.3"/>`,
  // Stacked lines
  `<line x1="70%" y1="20%" x2="95%" y2="20%" stroke="${patternColor}" stroke-width="3" opacity="0.5"/><line x1="72%" y1="35%" x2="90%" y2="35%" stroke="${patternColor}" stroke-width="3" opacity="0.4"/><line x1="74%" y1="50%" x2="92%" y2="50%" stroke="${patternColor}" stroke-width="3" opacity="0.3"/>`,
];
const shape = shapeVariants[h4 % shapeVariants.length];
---

<div
  class:list={['hero-image relative overflow-hidden', className]}
  style={`background: ${gradient};`}
  role="img"
  aria-label={title}
>
  <svg class="absolute inset-0 w-full h-full" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <defs set:html={patternSvg} />
    <rect width="100%" height="100%" fill={`url(#${patternId})`} />
    <Fragment set:html={shape} />
  </svg>
  <div class="absolute bottom-3 left-4 right-4">
    <span class="text-xs font-semibold uppercase tracking-widest opacity-70" style={`color: ${textColor};`}>
      {category || collection}
    </span>
  </div>
</div>

<style>
  .hero-image {
    aspect-ratio: 16 / 9;
  }
</style>
