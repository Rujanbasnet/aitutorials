---
import HeroImage from './HeroImage.astro';

interface Props {
  name: string;
  description: string;
  category: string;
  url: string;
  affiliateUrl?: string | null;
  pricing: string;
  pricingDetail: string;
  trending?: boolean;
  new?: boolean;
  image?: string | null;
}

const {
  name,
  description,
  category,
  url,
  affiliateUrl,
  pricing,
  pricingDetail,
  trending = false,
  image = null,
} = Astro.props;

// "new" is reserved in JS, so access via Astro.props directly
const isNew = Astro.props.new || false;

const linkUrl = affiliateUrl || url;
const isAffiliate = !!affiliateUrl;
---

<div class="group relative bg-[var(--color-bg-card)] border border-[var(--color-border)] rounded-xl overflow-hidden hover:border-[var(--color-border-strong)] hover:shadow-sm transition-all duration-300">
  {/* Image area */}
  {image ? (
    <div class="aspect-video overflow-hidden">
      <img
        src={image}
        alt={name}
        class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700 ease-out"
        loading="lazy"
      />
    </div>
  ) : (
    <HeroImage title={name} category={category} collection="tools" class="!aspect-[3/1]" />
  )}

  <div class="p-5">
    {/* Header row */}
    <div class="flex items-start justify-between mb-3">
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2 mb-1">
          <h3 class="text-base font-medium text-[var(--color-text-primary)] truncate" style="font-family: var(--font-display); font-size: 1.125rem;">
            {name}
          </h3>
          {isNew && (
            <span class="inline-flex items-center px-1.5 py-0.5 text-[0.6rem] font-bold uppercase tracking-wider rounded border border-[var(--color-sage)] text-[var(--color-sage)]">
              New
            </span>
          )}
          {trending && (
            <span class="inline-flex items-center px-1.5 py-0.5 text-[0.6rem] font-bold uppercase tracking-wider rounded border border-[var(--color-accent)] text-[var(--color-accent-hover)]">
              Trending
            </span>
          )}
        </div>
        <span class="tag">{category}</span>
      </div>
    </div>

    {/* Description */}
    <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-4 line-clamp-3">
      {description}
    </p>

    {/* Footer */}
    <div class="flex items-center justify-between">
      <div class="text-sm">
        <span class:list={[
          'font-medium',
          pricing === 'Free' ? 'text-[var(--color-sage)]' :
          pricing === 'Freemium' ? 'text-[var(--color-accent)]' :
          'text-[var(--color-text-secondary)]'
        ]}>
          {pricing}
        </span>
        {pricingDetail !== pricing && (
          <span class="text-[var(--color-text-muted)] text-xs ml-1">
            &middot; {pricingDetail}
          </span>
        )}
      </div>
      <a
        href={linkUrl}
        target="_blank"
        rel={isAffiliate ? "noopener nofollow sponsored" : "noopener nofollow"}
        class="inline-flex items-center gap-1.5 px-3.5 py-1.5 text-xs font-semibold rounded-lg bg-[var(--color-text-primary)] text-white hover:bg-[var(--color-accent)] hover:shadow-[0_4px_12px_rgba(217,119,6,0.25)] transition-all"
      >
        Visit
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
        </svg>
      </a>
    </div>
  </div>
</div>
