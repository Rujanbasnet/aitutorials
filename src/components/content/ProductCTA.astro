---
interface Props {
  title: string;
  description: string;
  price: number;
  currency?: string;
  href: string;
  productType?: string;
}

const {
  title,
  description,
  price,
  currency = 'USD',
  href,
  productType,
} = Astro.props;
---

<aside class="my-10 card-warm p-6 sm:p-8 rounded-xl not-prose">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div class="flex-1">
      {productType && (
        <span class="badge-intermediate text-xs font-semibold px-2 py-0.5 rounded-sm uppercase tracking-wide mb-2 inline-block">
          {productType.replace('-', ' ')}
        </span>
      )}
      <h4 class="text-lg text-[var(--color-text-primary)] mb-1" style="font-family: var(--font-display)">
        {title}
      </h4>
      <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
        {description}
      </p>
    </div>
    <div class="flex items-center gap-3 flex-shrink-0">
      <span class="text-lg font-semibold text-[var(--color-text-primary)]">
        {price === 0 ? 'Free' : `$${price}`}
      </span>
      <a
        href={href}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-[var(--color-accent)] text-white text-sm font-medium hover:bg-[var(--color-accent-hover)] transition-colors whitespace-nowrap"
      >
        {price === 0 ? 'Get it free' : 'Get it'}
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </div>
</aside>
