---
import { formatDateShort } from '@utils/dates';
import { getReadingTime } from '@utils/reading-time';
import HeroImage from './HeroImage.astro';

interface Props {
  title: string;
  description: string;
  href: string;
  pubDate: Date;
  tags?: string[];
  image?: string;
  body?: string;
  category?: string;
  collection?: string;
}

const { title, description, href, pubDate, tags = [], image, body = '', category = '', collection = '' } = Astro.props;
const readingTime = body ? getReadingTime(body) : '';
---

<a href={href} class="featured-card card-feature block overflow-hidden group md:col-span-2 lg:col-span-3">
  <div class="grid md:grid-cols-2 gap-0">
    <div class="featured-hero relative overflow-hidden">
      {image ? (
        <div class="aspect-video md:aspect-auto md:h-full overflow-hidden">
          <img
            src={image}
            alt={title}
            class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700 ease-out"
            loading="lazy"
          />
        </div>
      ) : (
        <HeroImage title={title} category={category} collection={collection} class="md:!aspect-auto md:h-full" />
      )}
      <div class="featured-shimmer"></div>
    </div>
    <div class="p-6 sm:p-8 lg:p-10 flex flex-col justify-center">
      <div class="flex flex-wrap items-center gap-2 mb-4">
        <span class="text-[0.6875rem] font-semibold px-2.5 py-0.5 rounded-sm uppercase tracking-wider" style="background: var(--color-accent-soft); color: var(--color-accent-hover);">Latest</span>
        {tags.slice(0, 2).map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
      <h3 class="text-2xl lg:text-3xl text-[var(--color-text-primary)] group-hover:text-[var(--color-accent)] transition-colors mb-3" style="font-family: var(--font-display)">
        {title}
      </h3>
      <p class="text-[var(--color-text-secondary)] mb-5 line-clamp-3 leading-relaxed">
        {description}
      </p>
      <div class="flex items-center gap-3 text-sm text-[var(--color-text-muted)]">
        <time datetime={pubDate.toISOString()}>
          {formatDateShort(pubDate)}
        </time>
        {readingTime && (
          <>
            <span class="opacity-40">&middot;</span>
            <span>{readingTime}</span>
          </>
        )}
      </div>
      <div class="mt-5 text-sm font-medium text-[var(--color-accent)] featured-cta inline-flex items-center gap-1.5">
        Read article
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </div>
    </div>
  </div>
</a>

<style>
  .featured-card {
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .featured-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 48px -12px rgba(20, 20, 19, 0.12);
  }

  .featured-shimmer {
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.15) 50%, transparent 60%);
    transform: translateX(-100%);
    transition: none;
    pointer-events: none;
  }
  .featured-card:hover .featured-shimmer {
    transform: translateX(100%);
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .featured-cta {
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .featured-card:hover .featured-cta {
    transform: translateX(4px);
  }

  @media (prefers-reduced-motion: reduce) {
    .featured-card { transition: none; }
    .featured-card:hover { transform: none; }
    .featured-shimmer { display: none; }
    .featured-cta { transition: none; }
  }
</style>
