---
import Search from './Search.astro';
import NavDropdown from './NavDropdown.astro';

const currentPath = Astro.url.pathname;

const learnPrefixes = ['/tutorials/', '/challenges/', '/paths/', '/non-coder/', '/resources/'];
const isLearnActive = learnPrefixes.some(prefix => currentPath.startsWith(prefix));

function isActive(href: string): boolean {
  if (href === '/articles/') {
    return currentPath.startsWith('/articles/') || currentPath.startsWith('/news/') || currentPath.startsWith('/blog/');
  }
  if (href === '/discover/') {
    return currentPath.startsWith('/discover/') || currentPath.startsWith('/tools/') || currentPath.startsWith('/products/');
  }
  return currentPath.startsWith(href);
}
---

<header class="glass-nav fixed top-0 left-0 right-0 z-50">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 group">
      <div class="nav-logo">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2L2 7l10 5 10-5-10-5z" />
          <path d="M2 17l10 5 10-5" />
          <path d="M2 12l10 5 10-5" />
        </svg>
      </div>
      <span class="nav-wordmark">
        <span class="nav-wordmark__ai">ai</span>tutorials
      </span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-0.5">
      <!-- Start Here -->
      <a
        href="/start/"
        class:list={[
          'nav-link nav-start px-3 py-1.5 text-sm rounded-lg transition-all',
          isActive('/start/')
            ? 'nav-active font-semibold'
            : 'font-semibold',
        ]}
        style="color: var(--color-accent);"
      >
        Start Here
      </a>

      <!-- Learn (dropdown trigger) -->
      <div class="relative" id="learn-trigger-wrap">
        <button
          class:list={[
            'nav-link px-3 py-1.5 text-sm rounded-lg transition-all hover-line flex items-center gap-1 cursor-pointer',
            isLearnActive
              ? 'nav-active font-semibold'
              : 'font-medium text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)]',
          ]}
          style={isLearnActive ? 'color: var(--color-accent);' : undefined}
          aria-expanded="false"
          aria-haspopup="true"
          id="learn-trigger"
        >
          Learn
          <svg class="nav-chevron w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
          </svg>
        </button>
        <NavDropdown currentPath={currentPath} />
      </div>

      <!-- News -->
      <a
        href="/articles/"
        class:list={[
          'nav-link px-3 py-1.5 text-sm rounded-lg transition-all hover-line',
          isActive('/articles/')
            ? 'nav-active font-semibold'
            : 'font-medium text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)]',
        ]}
        style={isActive('/articles/') ? 'color: var(--color-accent);' : undefined}
      >
        News
      </a>

      <!-- Tools -->
      <a
        href="/discover/"
        class:list={[
          'nav-link px-3 py-1.5 text-sm rounded-lg transition-all hover-line',
          isActive('/discover/')
            ? 'nav-active font-semibold'
            : 'font-medium text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)]',
        ]}
        style={isActive('/discover/') ? 'color: var(--color-accent);' : undefined}
      >
        Tools
      </a>
    </div>

    <!-- Actions -->
    <div class="flex items-center gap-3">
      <Search />
      <a
        href="/newsletter/"
        class="hidden sm:inline-flex items-center px-4 py-1.5 text-sm font-semibold rounded-lg bg-[var(--color-text-primary)] text-white hover:bg-[var(--color-accent)] transition-all hover:shadow-[0_4px_16px_rgba(217,119,6,0.25)]"
      >
        Subscribe
      </a>

      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors"
        aria-label="Toggle menu"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-[var(--color-border)]">
    <div class="px-4 py-3 space-y-0.5">
      <!-- Start Here -->
      <a
        href="/start/"
        class:list={[
          'block px-4 py-2.5 rounded-lg text-sm font-semibold transition-colors',
          isActive('/start/')
            ? 'bg-[var(--color-accent-soft)]'
            : 'hover:bg-[var(--color-bg-warm)]',
        ]}
        style="color: var(--color-accent);"
      >
        Start Here
      </a>

      <!-- Learn (accordion) -->
      <div>
        <button
          class:list={[
            'flex items-center justify-between w-full px-4 py-2.5 rounded-lg text-sm font-medium transition-colors cursor-pointer',
            isLearnActive
              ? 'bg-[var(--color-accent-soft)]'
              : 'hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-warm)]',
          ]}
          style={isLearnActive ? 'color: var(--color-accent);' : 'color: var(--color-text-secondary);'}
          aria-expanded="false"
          id="mobile-learn-toggle"
        >
          Learn
          <svg class="mobile-learn-chevron w-4 h-4 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
          </svg>
        </button>
        <div class="mobile-learn-items hidden ml-4 mt-0.5 mb-1 border-l-2 border-[var(--color-border)]" id="mobile-learn-items">
          <a href="/challenges/" class="block px-4 py-2 rounded-lg text-sm transition-colors hover:text-[var(--color-text-primary)]" style={currentPath.startsWith('/challenges/') ? 'color: var(--color-accent); font-weight: 500;' : 'color: var(--color-text-secondary);'}>
            Try It Yourself
          </a>
          <a href="/non-coder/" class="block px-4 py-2 rounded-lg text-sm transition-colors hover:text-[var(--color-text-primary)]" style={currentPath.startsWith('/non-coder/') ? 'color: var(--color-accent); font-weight: 500;' : 'color: var(--color-text-secondary);'}>
            Non-Coder Guides
          </a>
          <a href="/paths/" class="block px-4 py-2 rounded-lg text-sm transition-colors hover:text-[var(--color-text-primary)]" style={currentPath.startsWith('/paths/') ? 'color: var(--color-accent); font-weight: 500;' : 'color: var(--color-text-secondary);'}>
            Learning Paths
          </a>
          <a href="/tutorials/" class="block px-4 py-2 rounded-lg text-sm transition-colors hover:text-[var(--color-text-primary)]" style={currentPath.startsWith('/tutorials/') ? 'color: var(--color-accent); font-weight: 500;' : 'color: var(--color-text-secondary);'}>
            Tutorials
          </a>
          <a href="/resources/" class="block px-4 py-2 rounded-lg text-sm transition-colors hover:text-[var(--color-text-primary)]" style={currentPath.startsWith('/resources/') ? 'color: var(--color-accent); font-weight: 500;' : 'color: var(--color-text-secondary);'}>
            Resources
          </a>
        </div>
      </div>

      <!-- News -->
      <a
        href="/articles/"
        class:list={[
          'block px-4 py-2.5 rounded-lg text-sm font-medium transition-colors',
          isActive('/articles/')
            ? 'text-[var(--color-accent)] bg-[var(--color-accent-soft)]'
            : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-warm)]',
        ]}
      >
        News
      </a>

      <!-- Tools -->
      <a
        href="/discover/"
        class:list={[
          'block px-4 py-2.5 rounded-lg text-sm font-medium transition-colors',
          isActive('/discover/')
            ? 'text-[var(--color-accent)] bg-[var(--color-accent-soft)]'
            : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-warm)]',
        ]}
      >
        Tools
      </a>

      <!-- Subscribe -->
      <a href="/newsletter/" class="block px-4 py-2.5 rounded-lg text-sm font-medium text-[var(--color-accent)]">
        Subscribe
      </a>
    </div>
  </div>
</header>

<div class="h-16"></div>

<style>
  .nav-logo {
    width: 34px;
    height: 34px;
    border-radius: 10px;
    background: var(--color-text-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                background 0.3s,
                box-shadow 0.3s;
  }
  .group:hover .nav-logo {
    transform: scale(1.08) rotate(-3deg);
    background: var(--color-accent);
    color: #fff;
    box-shadow: 0 4px 16px rgba(217,119,6,0.3);
  }

  .nav-wordmark {
    font-family: var(--font-display);
    font-size: 1.125rem;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
  }
  .nav-wordmark__ai {
    color: var(--color-accent);
    font-style: italic;
  }

  .nav-active {
    position: relative;
  }
  .nav-active::after {
    content: '';
    position: absolute;
    left: 0.75rem;
    right: 0.75rem;
    bottom: -2px;
    height: 2px;
    background: var(--color-accent);
    border-radius: 1px;
  }

  .nav-chevron {
    transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  button[aria-expanded="true"] .nav-chevron {
    transform: rotate(180deg);
  }

  .mobile-learn-chevron {
    transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  button[aria-expanded="true"] .mobile-learn-chevron {
    transform: rotate(180deg);
  }
</style>

<script>
  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  menuBtn.addEventListener('click', () => mobileMenu.classList.toggle('hidden'));

  // Mobile Learn accordion
  const mobileToggle = document.getElementById('mobile-learn-toggle');
  const mobileItems = document.getElementById('mobile-learn-items');
  mobileToggle?.addEventListener('click', () => {
    const expanded = mobileToggle.getAttribute('aria-expanded') === 'true';
    mobileToggle.setAttribute('aria-expanded', String(!expanded));
    mobileItems?.classList.toggle('hidden');
  });

  // Desktop Learn dropdown
  const learnWrap = document.getElementById('learn-trigger-wrap');
  const learnBtn = document.getElementById('learn-trigger');
  const dropdown = document.getElementById('learn-dropdown');

  if (learnWrap && learnBtn && dropdown) {
    let openTimeout: ReturnType<typeof setTimeout> | null = null;
    let closeTimeout: ReturnType<typeof setTimeout> | null = null;

    function openDropdown() {
      if (closeTimeout) clearTimeout(closeTimeout);
      openTimeout = setTimeout(() => {
        dropdown.classList.add('is-open');
        learnBtn.setAttribute('aria-expanded', 'true');
      }, 80);
    }

    function closeDropdown() {
      if (openTimeout) clearTimeout(openTimeout);
      closeTimeout = setTimeout(() => {
        dropdown.classList.remove('is-open');
        learnBtn.setAttribute('aria-expanded', 'false');
      }, 150);
    }

    function closeImmediate() {
      if (openTimeout) clearTimeout(openTimeout);
      if (closeTimeout) clearTimeout(closeTimeout);
      dropdown.classList.remove('is-open');
      learnBtn.setAttribute('aria-expanded', 'false');
    }

    // Hover
    learnWrap.addEventListener('mouseenter', openDropdown);
    learnWrap.addEventListener('mouseleave', closeDropdown);

    // Click (accessibility + touch)
    learnBtn.addEventListener('click', (e) => {
      e.preventDefault();
      const isOpen = dropdown.classList.contains('is-open');
      if (isOpen) {
        closeImmediate();
      } else {
        if (closeTimeout) clearTimeout(closeTimeout);
        dropdown.classList.add('is-open');
        learnBtn.setAttribute('aria-expanded', 'true');
        const firstItem = dropdown.querySelector<HTMLElement>('[role="menuitem"]');
        firstItem?.focus();
      }
    });

    // Escape closes
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && dropdown.classList.contains('is-open')) {
        closeImmediate();
        learnBtn.focus();
      }
    });

    // Arrow keys within dropdown
    dropdown.addEventListener('keydown', (e) => {
      const items = [...dropdown.querySelectorAll<HTMLElement>('[role="menuitem"]')];
      const current = document.activeElement as HTMLElement;
      const index = items.indexOf(current);

      if (e.key === 'ArrowDown') {
        e.preventDefault();
        const next = items[index + 1] || items[0];
        next.focus();
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        const prev = items[index - 1] || items[items.length - 1];
        prev.focus();
      } else if (e.key === 'Tab') {
        closeImmediate();
      }
    });

    // Click outside closes
    document.addEventListener('click', (e) => {
      if (!learnWrap.contains(e.target as Node)) {
        closeImmediate();
      }
    });
  }
</script>
