---
import Search from './Search.astro';

const navLinks = [
  { label: 'Start Here', href: '/start/', highlight: true },
  { label: 'Tutorials', href: '/tutorials/' },
  { label: 'News', href: '/news/' },
  { label: 'Tools', href: '/tools/' },
  { label: 'Products', href: '/products/' },
];

const moreLinks = [
  { label: 'Blog', href: '/blog/' },
  { label: 'Challenges', href: '/challenges/' },
  { label: 'Non-Coder', href: '/non-coder/' },
  { label: 'Resources', href: '/resources/' },
  { label: 'Learning Paths', href: '/paths/' },
  { label: 'About', href: '/about/' },
];

const currentPath = Astro.url.pathname;
---

<header class="glass-nav fixed top-0 left-0 right-0 z-50">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 group">
      <div class="nav-logo">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2L2 7l10 5 10-5-10-5z" />
          <path d="M2 17l10 5 10-5" />
          <path d="M2 12l10 5 10-5" />
        </svg>
      </div>
      <span class="nav-wordmark">
        <span class="nav-wordmark__ai">ai</span>tutorials
      </span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-0.5">
      {navLinks.map((link) => {
        const isActive = currentPath.startsWith(link.href);
        return (
          <a
            href={link.href}
            class:list={[
              'nav-link px-3 py-1.5 text-sm rounded-lg transition-all hover-line',
              isActive
                ? 'nav-active font-semibold'
                : link.highlight
                  ? 'font-semibold text-[var(--color-accent)] hover:bg-[var(--color-accent-soft)]'
                  : 'font-medium text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)]',
            ]}
            style={isActive ? 'color: var(--color-accent);' : undefined}
          >
            {link.label}
          </a>
        );
      })}

      <!-- More dropdown -->
      <div class="nav-dropdown-wrap relative">
        <button
          class="nav-link px-3 py-1.5 text-sm font-medium text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors rounded-lg flex items-center gap-1"
          id="nav-more-btn"
          aria-expanded="false"
        >
          More
          <svg class="w-3.5 h-3.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
          </svg>
        </button>
        <div id="nav-more-menu" class="nav-dropdown hidden">
          {moreLinks.map((link) => {
            const isActive = currentPath.startsWith(link.href);
            return (
              <a
                href={link.href}
                class:list={[
                  'nav-dropdown__item',
                  isActive && 'nav-dropdown__item--active',
                ]}
              >
                {link.label}
              </a>
            );
          })}
        </div>
      </div>
    </div>

    <!-- Actions -->
    <div class="flex items-center gap-3">
      <Search />
      <a
        href="/newsletter/"
        class="hidden sm:inline-flex items-center px-4 py-1.5 text-sm font-semibold rounded-lg bg-[var(--color-text-primary)] text-white hover:bg-[var(--color-accent)] transition-all hover:shadow-[0_4px_16px_rgba(217,119,6,0.25)]"
      >
        Subscribe
      </a>

      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg text-[var(--color-text-muted)] hover:text-[var(--color-text-primary)] transition-colors"
        aria-label="Toggle menu"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="md:hidden hidden border-t border-[var(--color-border)]">
    <div class="px-4 py-3 space-y-0.5">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'block px-4 py-2.5 rounded-lg text-sm font-medium transition-colors',
            currentPath.startsWith(link.href)
              ? 'text-[var(--color-accent)] bg-[var(--color-accent-soft)]'
              : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-warm)]',
          ]}
        >
          {link.label}
        </a>
      ))}
      <div class="pt-2 mt-2 border-t border-[var(--color-border)]">
        <p class="px-4 py-1.5 text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)]">More</p>
        {moreLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'block px-4 py-2 rounded-lg text-sm font-medium transition-colors',
              currentPath.startsWith(link.href)
                ? 'text-[var(--color-accent)] bg-[var(--color-accent-soft)]'
                : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] hover:bg-[var(--color-bg-warm)]',
            ]}
          >
            {link.label}
          </a>
        ))}
      </div>
      <a href="/newsletter/" class="block px-4 py-2.5 rounded-lg text-sm font-medium text-[var(--color-accent)]">
        Subscribe
      </a>
    </div>
  </div>
</header>

<div class="h-16"></div>

<style>
  .nav-logo {
    width: 34px;
    height: 34px;
    border-radius: 10px;
    background: var(--color-text-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-accent);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                background 0.3s,
                box-shadow 0.3s;
  }
  .group:hover .nav-logo {
    transform: scale(1.08) rotate(-3deg);
    background: var(--color-accent);
    color: #fff;
    box-shadow: 0 4px 16px rgba(217,119,6,0.3);
  }

  .nav-wordmark {
    font-family: var(--font-display);
    font-size: 1.125rem;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
  }
  .nav-wordmark__ai {
    color: var(--color-accent);
    font-style: italic;
  }

  .nav-active {
    position: relative;
  }
  .nav-active::after {
    content: '';
    position: absolute;
    left: 0.75rem;
    right: 0.75rem;
    bottom: -2px;
    height: 2px;
    background: var(--color-accent);
    border-radius: 1px;
  }

  /* Dropdown */
  .nav-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 180px;
    padding: 6px;
    border-radius: 14px;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    box-shadow: 0 12px 40px rgba(20,20,19,0.12), 0 0 0 1px rgba(20,20,19,0.03);
    z-index: 100;
    animation: dropdown-in 0.2s ease;
  }
  @keyframes dropdown-in {
    from { opacity: 0; transform: translateY(-8px) scale(0.96); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  .nav-dropdown__item {
    display: block;
    padding: 8px 14px;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    border-radius: 8px;
    transition: all 0.15s;
  }
  .nav-dropdown__item:hover {
    background: var(--color-bg-warm);
    color: var(--color-text-primary);
  }
  .nav-dropdown__item--active {
    color: var(--color-accent);
    background: var(--color-accent-soft);
  }
</style>

<script>
  // Mobile menu
  const menuBtn = document.getElementById('mobile-menu-btn')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  menuBtn.addEventListener('click', () => mobileMenu.classList.toggle('hidden'));

  // Desktop "More" dropdown
  const moreBtn = document.getElementById('nav-more-btn')!;
  const moreMenu = document.getElementById('nav-more-menu')!;

  moreBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = !moreMenu.classList.contains('hidden');
    moreMenu.classList.toggle('hidden');
    moreBtn.setAttribute('aria-expanded', String(!isOpen));
    const chevron = moreBtn.querySelector('svg');
    if (chevron) chevron.style.transform = isOpen ? '' : 'rotate(180deg)';
  });

  // Close dropdown on outside click
  document.addEventListener('click', () => {
    moreMenu.classList.add('hidden');
    moreBtn.setAttribute('aria-expanded', 'false');
    const chevron = moreBtn.querySelector('svg');
    if (chevron) chevron.style.transform = '';
  });

  // Prevent dropdown from closing when clicking inside it
  moreMenu.addEventListener('click', (e) => e.stopPropagation());
</script>
